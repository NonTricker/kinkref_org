---
/**
 * Footer — 站台頁腳
 *
 * 區塊：簡介 / 導航 / 治理 / 授權聲明 / 建置記錄
 *
 * V2 Polish (2026-05-03)：加入 version / git short hash / build date 三件套，
 * 致敬 Stanford SEP / Are.na 等學術站的「建置可追蹤」作風。
 */

import { buildInfo } from '../lib/build-info';

const currentYear = new Date().getFullYear();

// Crew · 工作組 — 致敬實作層執行者
// v0.5.7：保留貢獻認可，等未來追認
// v0.5.8：codename + 本名並列、標 (AI Agent)
// v0.5.9（執政官指示）：拆「人類團隊」+「AI 工作組」兩塊，未來各自能擴
const humanCrew = [
  { role: '策展人', name: '薩約' },
];

const agentCrew = [
  { role: '撰寫者', codename: '靈範師', name: '繆思' },
  { role: '前端工程師', codename: '織法者', name: '紬' },
  { role: '符號師', codename: '銘文師', name: '席琳' },
  { role: '視覺設計', codename: '光影師', name: '艾莉兒' },
];

const footerSections = [
  {
    heading: '內容',
    links: [
      { href: '/glossary', label: '術語表' },
      { href: '/bibliography', label: '文獻指南' },
      { href: '/books', label: '書架清單' },
      { href: '/journals', label: '投稿地圖' },
    ],
  },
  {
    heading: 'Resources',
    links: [
      { href: '/resources#counselors', label: '心理資源' },
      { href: '/resources#legal', label: '法律資源' },
      { href: '/resources#campus-groups', label: '社團資源' },
      { href: '/resources#medical', label: '醫療資源' },
      { href: '/resources#other', label: '其他資源' },
    ],
  },
  {
    heading: '專案',
    links: [
      { href: '/about', label: '關於' },
      { href: '/qa', label: '常見問題' },
      { href: '/contribute', label: '貢獻' },
      { href: 'https://github.com/NonTricker/kinkref_org', label: 'GitHub', external: true, me: true },
    ],
  },
  {
    heading: '治理',
    links: [
      { href: '/about#editorial', label: '編輯立場' },
      { href: '/about#governance', label: '治理模型' },
      { href: '/about#contact', label: '聯絡' },
    ],
  },
];
---

<footer class="site-footer">
  <div class="site-footer-inner">
    <div class="site-footer-top">
      <div class="site-footer-about">
        <p class="site-footer-brand">Kink Reference</p>
        <p class="site-footer-tagline">中文 BDSM 學術文獻策展與術語索引</p>
        <p class="site-footer-tagline-en">
          Curating BDSM scholarship for the Traditional Chinese reading public.
        </p>
      </div>

      <nav class="site-footer-nav" aria-label="頁腳導航">
        {
          footerSections.map((section) => (
            <div class="site-footer-section">
              <h2 class="site-footer-heading">{section.heading}</h2>
              <ul>
                {section.links.map((link) => {
                  const isExternal = 'external' in link && link.external;
                  const isMe = 'me' in link && link.me;
                  // rel 組合：external 用 noopener noreferrer；rel=me（IndieWeb 身分串連）用於 GitHub link
                  const relTokens = [
                    isExternal && 'noopener',
                    isExternal && 'noreferrer',
                    isMe && 'me',
                  ].filter(Boolean);
                  const rel = relTokens.length > 0 ? relTokens.join(' ') : undefined;
                  return (
                    <li>
                      <a
                        href={link.href}
                        {...(isExternal ? { target: '_blank' } : {})}
                        {...(rel ? { rel } : {})}
                      >
                        {link.label}
                      </a>
                    </li>
                  );
                })}
              </ul>
            </div>
          ))
        }
      </nav>
    </div>

    <section class="site-footer-crew" aria-label="Crew · 工作組">
      <p class="crew-heading">
        <span class="crew-heading-zh">工作組</span>
        <span class="crew-heading-sep" aria-hidden="true">·</span>
        <span class="crew-heading-en">Crew</span>
      </p>

      <div class="crew-grid">
        <div class="crew-block">
          <p class="crew-block-heading">
            <span>人類團隊</span>
            <span class="crew-block-heading-sep" aria-hidden="true">·</span>
            <span class="crew-block-heading-en">Human</span>
          </p>
          <ul class="crew-list">
            {
              humanCrew.map((member) => (
                <li class="crew-item">
                  <span class="crew-role">{member.role}</span>
                  <span class="crew-name">{member.name}</span>
                </li>
              ))
            }
          </ul>
        </div>

        <div class="crew-block crew-block--agents">
          <p class="crew-block-heading">
            <span>AI 工作組</span>
            <span class="crew-block-heading-sep" aria-hidden="true">·</span>
            <span class="crew-block-heading-en">Agents</span>
          </p>
          <ul class="crew-list crew-list--two-col">
            {
              agentCrew.map((member) => (
                <li class="crew-item">
                  <span class="crew-role">{member.role}</span>
                  <span class="crew-name">
                    <span class="crew-codename">{member.codename}</span>
                    <span class="crew-name-sep" aria-hidden="true">．</span>
                    {member.name}
                  </span>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </section>

    <div class="site-footer-bottom">
      <p class="site-footer-license">
        本站內容採
        <a href="https://creativecommons.org/licenses/by-sa/4.0/" rel="license">
          CC BY-SA 4.0
        </a>
        授權。引用請註明來源。
      </p>
      <p class="site-footer-copyright">© 2026 — {currentYear} Kink Reference</p>
    </div>

    <p class="site-footer-build" aria-label="建置資訊">
      <span class="build-version">v{buildInfo.version}</span>
      <span class="build-sep" aria-hidden="true">·</span>
      <span class="build-hash">#{buildInfo.gitHash}</span>
      <span class="build-sep" aria-hidden="true">·</span>
      <span class="build-date">built {buildInfo.buildDate}</span>
    </p>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--bg-footer);
    color: var(--ink-inverse);
    margin-top: var(--space-12);
  }

  .site-footer-inner {
    max-width: var(--content-width-wide);
    margin: 0 auto;
    padding: var(--space-11) var(--space-5) var(--space-7);
  }

  .site-footer-top {
    display: grid;
    grid-template-columns: 1.4fr 2fr;
    gap: var(--space-9);
    padding-bottom: var(--space-9);
    border-bottom: 1px solid color-mix(in srgb, var(--ink-inverse) 20%, transparent);
  }

  .site-footer-brand {
    font-family: var(--font-serif);
    font-size: var(--fs-h3);
    font-weight: var(--fw-bold);
    color: var(--ink-inverse);
    margin: 0 0 var(--space-3);
  }

  .site-footer-tagline {
    font-family: var(--font-sans);
    font-size: var(--fs-body-sm);
    color: color-mix(in srgb, var(--ink-inverse) 80%, transparent);
    margin: 0 0 var(--space-2);
  }

  .site-footer-tagline-en {
    font-family: var(--font-sans);
    font-size: var(--fs-caption);
    color: color-mix(in srgb, var(--ink-inverse) 60%, transparent);
    margin: 0;
    font-style: italic;
  }

  .site-footer-nav {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-7);
  }

  .site-footer-heading {
    font-family: var(--font-sans);
    font-size: var(--fs-eyebrow);
    text-transform: uppercase;
    letter-spacing: var(--ls-eyebrow);
    color: color-mix(in srgb, var(--ink-inverse) 70%, transparent);
    margin: 0 0 var(--space-4);
  }

  .site-footer-section ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .site-footer-section a {
    color: var(--ink-inverse);
    text-decoration: none;
    font-family: var(--font-sans);
    font-size: var(--fs-ui);
    transition: var(--transition-color);
  }

  .site-footer-section a:hover {
    color: var(--accent-primary);
  }

  /* ──────────────────────────────────────────────────────
     Crew colophon — 致敬實作層執行者
     對標：NYRB masthead / Aeon editorial colophon
     v0.5.9：拆「人類團隊」+「AI 工作組」兩塊，未來各自能擴
     ────────────────────────────────────────────────────── */
  .site-footer-crew {
    /* 上方 border 由 site-footer-top 的 border-bottom 提供，這裡只給氣息 */
    padding-top: var(--space-7);
  }

  .crew-heading {
    margin: 0 0 var(--space-5);
    font-family: var(--font-sans);
    font-size: var(--fs-eyebrow);
    text-transform: uppercase;
    letter-spacing: var(--ls-eyebrow);
    color: color-mix(in srgb, var(--ink-inverse) 70%, transparent);
    display: inline-flex;
    align-items: baseline;
    gap: 6px;
  }

  .crew-heading-sep {
    color: color-mix(in srgb, var(--ink-inverse) 30%, transparent);
  }

  /* 兩欄結構：人類團隊（左）+ AI 工作組（右）。寬螢幕並排，行動上下堆疊
     v0.5.12：human 區自適（auto），剩餘空間全給 agents 區放兩列 */
  .crew-grid {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-7) var(--space-9);
  }

  .crew-block-heading {
    margin: 0 0 var(--space-3);
    font-family: var(--font-sans);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: color-mix(in srgb, var(--ink-inverse) 50%, transparent);
    display: inline-flex;
    align-items: baseline;
    gap: 6px;
    font-weight: var(--fw-semibold);
  }

  .crew-block-heading-sep {
    color: color-mix(in srgb, var(--ink-inverse) 25%, transparent);
    font-weight: var(--fw-regular);
  }

  .crew-block-heading-en {
    color: color-mix(in srgb, var(--ink-inverse) 60%, transparent);
  }

  /* 每個 list 改為單欄 flex column —— 每行自己一個 row，
     (codename．name) 不再被 grid 壓得擠到折行。 */
  .crew-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  /* AI 工作組變體：兩列排（v0.5.12 執政官指示） */
  .crew-list--two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-2) var(--space-7);
  }

  .crew-item {
    display: flex;
    align-items: baseline;
    gap: var(--space-4);
    font-family: var(--font-sans);
    font-size: var(--fs-caption);
    line-height: 1.5;
    /* 防止內部任何東西折行 — colophon 必須一行寫完 */
    white-space: nowrap;
  }

  .crew-role {
    /* 角色 label：偏 meta 灰，類 dl > dt 結構 */
    flex: 0 0 auto;
    min-width: 7em;
    color: color-mix(in srgb, var(--ink-inverse) 55%, transparent);
    font-weight: var(--fw-regular);
  }

  .crew-name {
    /* 名字主體：白色，比 role 重 */
    color: var(--ink-inverse);
    font-weight: var(--fw-medium);
  }

  .crew-codename {
    /* codename 跟本名同字級同色，靠中間 ．分隔 */
    color: var(--ink-inverse);
    font-weight: var(--fw-medium);
  }

  .crew-name-sep {
    margin: 0 4px;
    color: color-mix(in srgb, var(--ink-inverse) 30%, transparent);
    font-weight: var(--fw-regular);
  }

  /* 行動版：兩欄堆疊為單欄 */
  @media (max-width: 720px) {
    .crew-grid {
      grid-template-columns: 1fr;
    }

    /* AI 工作組兩列在窄螢幕也降回單列 */
    .crew-list--two-col {
      grid-template-columns: 1fr;
    }

    .crew-item {
      /* 行動小螢幕允許折行（避免水平 scroll） */
      white-space: normal;
    }
  }

  .site-footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-5);
    padding-top: var(--space-7);
    margin-top: var(--space-7);
    border-top: 1px solid color-mix(in srgb, var(--ink-inverse) 12%, transparent);
    flex-wrap: wrap;
    font-family: var(--font-sans);
    font-size: var(--fs-caption);
    color: color-mix(in srgb, var(--ink-inverse) 70%, transparent);
  }

  .site-footer-bottom a {
    color: var(--ink-inverse);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .site-footer-license {
    margin: 0;
  }

  .site-footer-copyright {
    margin: 0;
    font-variant-numeric: tabular-nums;
  }

  /* ──────────────────────────────────────────────────────
     Build info — 學術站「建置可追蹤」作風
     對標：Stanford SEP 的 build timestamp / Are.na 的 git hash
     ────────────────────────────────────────────────────── */
  .site-footer-build {
    margin: var(--space-5) 0 0;
    padding-top: var(--space-4);
    border-top: 1px solid color-mix(in srgb, var(--ink-inverse) 12%, transparent);
    font-family: var(--font-mono);
    font-size: 11px;
    color: color-mix(in srgb, var(--ink-inverse) 50%, transparent);
    letter-spacing: 0.04em;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    align-items: baseline;
  }

  .build-version,
  .build-hash,
  .build-date {
    font-variant-numeric: tabular-nums;
  }

  .build-hash {
    color: color-mix(in srgb, var(--ink-inverse) 65%, transparent);
  }

  .build-sep {
    color: color-mix(in srgb, var(--ink-inverse) 30%, transparent);
  }

  @media (max-width: 768px) {
    .site-footer-top {
      grid-template-columns: 1fr;
      gap: var(--space-7);
    }

    .site-footer-nav {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
