---
/**
 * Header — 站台頂部導航
 *
 * 結構：站名 + 主要導航 + Search 入口 + Theme toggle（將由光影師細修）。
 */

import KrMonogram from '@components/KrMonogram.astro';

const navItems = [
  { href: '/glossary', label: '術語表', en: 'Glossary' },
  { href: '/bibliography', label: '文獻指南', en: 'Bibliography' },
  { href: '/books', label: '書架清單', en: 'Books' },
  { href: '/journals', label: '投稿地圖', en: 'Journals' },
  { href: '/resources', label: '外部資源', en: 'Resources' },
  { href: '/contribute', label: '貢獻參與', en: 'Contribute' },
  { href: '/about', label: '關於本站', en: 'About' },
];

const currentPath = Astro.url.pathname;

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header class="site-header">
  <div class="site-header-inner">
    <a href="/" class="site-brand" aria-label="Kink Reference 首頁">
      <span class="site-brand-mark" aria-hidden="true">
        <KrMonogram size={48} class="site-brand-monogram" />
      </span>
      <span class="site-brand-text">
        <span class="site-brand-zh">
          中文 BDSM 學術策展
          <span class="site-brand-zh-sep" aria-hidden="true">·</span>
          <span class="site-brand-zh-tag">開源</span>
        </span>
        <span class="site-brand-en">
          <span class="site-brand-en-name">Kink Reference</span>
          <span class="site-brand-en-sep" aria-hidden="true">·</span>
          <span class="site-brand-en-locale">OSS · CC BY-SA</span>
        </span>
      </span>
    </a>

    <nav class="site-nav" aria-label="主要導航">
      <ul>
        {
          navItems.map((item) => (
            <li>
              <a
                href={item.href}
                class:list={['site-nav-link', { 'is-active': isActive(item.href) }]}
                aria-current={isActive(item.href) ? 'page' : undefined}
                title={item.en}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="site-actions">
      <a
        href="https://github.com/NonTricker/kinkref_org"
        class="action-btn github-btn"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="GitHub repo（開源）"
        title="GitHub · Open Source"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          width="18"
          height="18"
          fill="currentColor"
          aria-hidden="true"
        >
          <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
        </svg>
      </a>
      <button
        type="button"
        id="theme-toggle"
        class="action-btn theme-toggle"
        aria-label="切換主題"
        title="切換亮 / 暗主題"
      >
        <span class="theme-toggle-icon" aria-hidden="true">◐</span>
      </button>
    </div>
  </div>
</header>

<script is:inline>
  (function () {
    const btn = document.getElementById('theme-toggle');
    if (!btn) return;
    btn.addEventListener('click', () => {
      const root = document.documentElement;
      const current = root.getAttribute('data-theme');
      const next = current === 'dark' ? 'light' : 'dark';
      root.setAttribute('data-theme', next);
      try {
        localStorage.setItem('kinkref-theme', next);
      } catch {
        /* no-op */
      }
    });
  })();
</script>

<style>
  .site-header {
    /* Iron Law (DESIGN.md §6): 禁 backdrop-blur。改用純色高不透明度達成 sticky 視覺分離。 */
    border-bottom: 1px solid var(--rule-fine);
    background: var(--bg-base);
    position: sticky;
    top: 0;
    z-index: var(--z-sticky-nav);
  }

  .site-header-inner {
    max-width: var(--content-width-wide);
    margin: 0 auto;
    padding: var(--space-4) var(--space-5);
    display: flex;
    align-items: center;
    gap: var(--space-7);
  }

  .site-brand {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    text-decoration: none;
    color: var(--ink-heading);
    /* Decision: Wordmark 升級採 B+D 混合（手調字距 + baseline rule + sub-locale） */
  }

  /* KR Monogram — V5.7 SVG (銘文師席琳 2026-05-03)
     11 elements: K stem + R stem + R bowl + K leg + R leg + K upper arm
                 + 左 cuff + 右 cuff + 連結 line + 兩側 hairlines。
     fill="currentColor" 跟隨 .site-brand-mark color，dark mode 自動切換。 */
  .site-brand-mark {
    display: inline-flex;
    align-items: center;
    color: var(--accent-primary);
    line-height: 0;
  }

  .site-brand-monogram {
    display: block;
  }

  .site-brand-text {
    display: flex;
    flex-direction: column;
    line-height: 1.25;
    gap: 2px;
  }

  .site-brand-zh {
    font-size: var(--fs-ui);
    font-family: var(--font-sans);
    font-weight: var(--fw-semibold);
    letter-spacing: 0.02em;
    display: inline-flex;
    align-items: baseline;
    gap: 6px;
  }

  .site-brand-zh-sep {
    color: var(--ink-disabled);
    font-weight: var(--fw-regular);
  }

  /* 「開源」chip — 中文版本，跟英文行 OSS · CC BY-SA 呼應
     v0.5.7：染紅統一站色（執政官指示「色調純一點」） */
  .site-brand-zh-tag {
    color: var(--accent-primary);
    font-weight: var(--fw-medium);
  }

  .site-brand-en {
    font-size: var(--fs-eyebrow);
    font-family: var(--font-sans);
    color: var(--ink-meta);
    letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .site-brand-en-sep {
    color: var(--ink-disabled);
  }

  .site-brand-en-locale {
    font-weight: var(--fw-semibold);
    color: var(--accent-primary); /* v0.5.7：染紅統一站色（執政官指示「色調純一點」） */
  }

  .site-nav {
    flex: 1;
  }

  .site-nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
    align-items: stretch;
  }

  /* 純中文 nav — 書頁標籤 (tab) 感
     - 統一 padding 讓視覺重量一致（不用 fixed width，避免短中文周邊空蕩）
     - active / hover 用 baseline rule grow 取代純色變化
     - 雙語識別已在 page hero 的 eyebrow 編號（01 · Glossary 等）內顯示，nav 不再重複
  */
  .site-nav-link {
    position: relative;
    display: inline-flex;
    align-items: center;
    padding: var(--space-3) var(--space-3);
    text-decoration: none;
    color: var(--ink-body);
    font-family: var(--font-sans);
    font-size: var(--fs-ui);
    font-weight: var(--fw-medium);
    letter-spacing: 0.02em;
    line-height: 1.4;
    transition: var(--transition-color);
  }

  /* baseline rule — active / hover 時從 center grow 出來 */
  .site-nav-link::after {
    content: '';
    position: absolute;
    left: var(--space-3);
    right: var(--space-3);
    bottom: -1px;
    height: 2px;
    background: var(--accent-primary);
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 200ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .site-nav-link:hover {
    color: var(--accent-primary);
  }

  .site-nav-link:hover::after {
    transform: scaleX(0.7);
  }

  .site-nav-link.is-active {
    color: var(--accent-primary);
  }

  .site-nav-link.is-active::after {
    transform: scaleX(1);
  }

  .site-nav-link:focus-visible {
    outline: 2px solid var(--accent-primary);
    outline-offset: 2px;
    border-radius: var(--radius-sm);
  }

  /* 右側 actions group：GitHub link + theme toggle，統一外觀 */
  .site-actions {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
  }

  .action-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: transparent;
    border: 1px solid var(--rule-fine);
    border-radius: var(--radius-sm);
    color: var(--ink-meta);
    cursor: pointer;
    text-decoration: none;
    transition: var(--transition-color);
  }

  .action-btn:hover {
    color: var(--accent-primary);
    border-color: var(--accent-primary);
  }

  .action-btn:focus-visible {
    outline: 2px solid var(--accent-primary);
    outline-offset: 2px;
  }

  .theme-toggle {
    font-size: var(--fs-body);
    line-height: 1;
    padding: 0;
  }

  .github-btn svg {
    display: block;
  }

  @media (max-width: 720px) {
    .site-header-inner {
      flex-wrap: wrap;
    }

    .site-nav ul {
      gap: var(--space-4);
    }
  }
</style>
