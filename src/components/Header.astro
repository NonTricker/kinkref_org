---
/**
 * Header — 站台頂部導航
 *
 * 結構：站名 + 主要導航 + Search 入口 + Theme toggle（將由光影師細修）。
 */

const navItems = [
  { href: '/glossary', label: '術語表', en: 'Glossary' },
  { href: '/bibliography', label: '文獻指南', en: 'Bibliography' },
  { href: '/books', label: '書架清單', en: 'Books' },
  { href: '/journals', label: '期刊指南', en: 'Journals' },
  { href: '/resources', label: '資源', en: 'Resources' },
  { href: '/contribute', label: '貢獻', en: 'Contribute' },
  { href: '/about', label: '關於', en: 'About' },
];

const currentPath = Astro.url.pathname;

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header class="site-header">
  <div class="site-header-inner">
    <a href="/" class="site-brand" aria-label="Kink Reference 首頁">
      <span class="site-brand-mark" aria-hidden="true">
        <span class="site-brand-mark-letter">K</span><span class="site-brand-mark-letter">R</span>
      </span>
      <span class="site-brand-text">
        <span class="site-brand-zh">中文 BDSM 學術文獻索引</span>
        <span class="site-brand-en">
          <span class="site-brand-en-name">Kink Reference</span>
          <span class="site-brand-en-sep" aria-hidden="true">·</span>
          <span class="site-brand-en-locale">TR</span>
        </span>
      </span>
    </a>

    <nav class="site-nav" aria-label="主要導航">
      <ul>
        {
          navItems.map((item) => (
            <li>
              <a
                href={item.href}
                class:list={['site-nav-link', { 'is-active': isActive(item.href) }]}
                aria-current={isActive(item.href) ? 'page' : undefined}
                title={item.en}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <button
      type="button"
      id="theme-toggle"
      class="theme-toggle"
      aria-label="切換主題"
      title="切換亮 / 暗主題"
    >
      <span class="theme-toggle-icon" aria-hidden="true">◐</span>
    </button>
  </div>
</header>

<script is:inline>
  (function () {
    const btn = document.getElementById('theme-toggle');
    if (!btn) return;
    btn.addEventListener('click', () => {
      const root = document.documentElement;
      const current = root.getAttribute('data-theme');
      const next = current === 'dark' ? 'light' : 'dark';
      root.setAttribute('data-theme', next);
      try {
        localStorage.setItem('kinkref-theme', next);
      } catch {
        /* no-op */
      }
    });
  })();
</script>

<style>
  .site-header {
    /* Iron Law (DESIGN.md §6): 禁 backdrop-blur。改用純色高不透明度達成 sticky 視覺分離。 */
    border-bottom: 1px solid var(--rule-fine);
    background: var(--bg-base);
    position: sticky;
    top: 0;
    z-index: var(--z-sticky-nav);
  }

  .site-header-inner {
    max-width: var(--content-width-wide);
    margin: 0 auto;
    padding: var(--space-4) var(--space-5);
    display: flex;
    align-items: center;
    gap: var(--space-7);
  }

  .site-brand {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    text-decoration: none;
    color: var(--ink-heading);
    /* Decision: Wordmark 升級採 B+D 混合（手調字距 + baseline rule + sub-locale） */
  }

  /* KR Monogram — 兩字母手調字距 + 底部 hairline baseline rule */
  .site-brand-mark {
    font-family: var(--font-serif);
    font-size: 1.625rem; /* 26px — 比 fs-h3 (20px) 略大，但小於 fs-h2 (26px) 等同壓在 H2 重量 */
    font-weight: var(--fw-bold);
    color: var(--accent-primary);
    line-height: 1;
    display: inline-flex;
    align-items: baseline;
    padding-bottom: 4px;
    border-bottom: 1px solid var(--accent-primary);
    /* small-caps 字距：兩字母之間留 0.04em 呼吸（Tiempos / IBM Plex Serif 風） */
    letter-spacing: 0.04em;
  }

  .site-brand-mark-letter {
    font-feature-settings: "ss01" on; /* serif stylistic set 若字體支援 */
  }

  .site-brand-text {
    display: flex;
    flex-direction: column;
    line-height: 1.25;
    gap: 2px;
  }

  .site-brand-zh {
    font-size: var(--fs-ui);
    font-family: var(--font-sans);
    font-weight: var(--fw-semibold);
    letter-spacing: 0.02em;
  }

  .site-brand-en {
    font-size: var(--fs-eyebrow);
    font-family: var(--font-sans);
    color: var(--ink-meta);
    letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .site-brand-en-sep {
    color: var(--ink-disabled);
  }

  .site-brand-en-locale {
    font-weight: var(--fw-semibold);
    color: var(--accent-citation); /* Bronze Citation — 區域標記像書扉頁的版本記號 */
  }

  .site-nav {
    flex: 1;
  }

  .site-nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
    align-items: stretch;
  }

  /* 純中文 nav — 書頁標籤 (tab) 感
     - 統一 padding 讓視覺重量一致（不用 fixed width，避免短中文周邊空蕩）
     - active / hover 用 baseline rule grow 取代純色變化
     - 雙語識別已在 page hero 的 eyebrow 編號（01 · Glossary 等）內顯示，nav 不再重複
  */
  .site-nav-link {
    position: relative;
    display: inline-flex;
    align-items: center;
    padding: var(--space-3) var(--space-3);
    text-decoration: none;
    color: var(--ink-body);
    font-family: var(--font-sans);
    font-size: var(--fs-ui);
    font-weight: var(--fw-medium);
    letter-spacing: 0.02em;
    line-height: 1.4;
    transition: var(--transition-color);
  }

  /* baseline rule — active / hover 時從 center grow 出來 */
  .site-nav-link::after {
    content: '';
    position: absolute;
    left: var(--space-3);
    right: var(--space-3);
    bottom: -1px;
    height: 2px;
    background: var(--accent-primary);
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 200ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .site-nav-link:hover {
    color: var(--accent-primary);
  }

  .site-nav-link:hover::after {
    transform: scaleX(0.7);
  }

  .site-nav-link.is-active {
    color: var(--accent-primary);
  }

  .site-nav-link.is-active::after {
    transform: scaleX(1);
  }

  .site-nav-link:focus-visible {
    outline: 2px solid var(--accent-primary);
    outline-offset: 2px;
    border-radius: var(--radius-sm);
  }

  .theme-toggle {
    background: transparent;
    border: 1px solid var(--rule-fine);
    border-radius: var(--radius-sm);
    color: var(--ink-meta);
    padding: var(--space-2) var(--space-3);
    font-size: var(--fs-body);
    line-height: 1;
    transition: var(--transition-color);
  }

  .theme-toggle:hover {
    color: var(--accent-primary);
    border-color: var(--accent-primary);
  }

  @media (max-width: 720px) {
    .site-header-inner {
      flex-wrap: wrap;
    }

    .site-nav ul {
      gap: var(--space-4);
    }
  }
</style>
