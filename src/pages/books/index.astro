---
/**
 * Books index — 書架清單列表頁
 *
 * v0.3.0 加入篩選器：topic_tags / book_type / has_zh_translation / difficulty
 */

import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import SearchBox from '@components/SearchBox.astro';
import TagPill from '@components/TagPill.astro';
import { renderInlineMarkdown, stripInlineMarkdown } from '@/lib/inline-markdown';

const allBooks = await getCollection('books');
const sortedBooks = allBooks.sort((a, b) => b.data.year - a.data.year);

// 收集篩選器來源
const allTopicTags = [...new Set(allBooks.flatMap((b) => b.data.topic_tags))].sort();
const allBookTypes = [...new Set(allBooks.map((b) => b.data.book_type))].sort();
const allDifficulties = [...new Set(allBooks.map((b) => b.data.difficulty))].sort();
const hasAnyZhTranslation = allBooks.some((b) => b.data.has_zh_translation);

const pageTitle = '書架清單 · Books';
const pageDescription = `${allBooks.length} 本跨日中英三文化的書目。首批含**歐美教學經典**（Topping/Bottom Book、SM 101、Screw the Roses）、**reference**（Different Loving）、**學術民族誌**（Newmahr）、**中文圈代表**（李銀河、小林繩霧）+ **日本傳統**（蒼月流）。每本附中文書摘與取得方式。`;
const metaDescription = stripInlineMarkdown(pageDescription);
---

<BaseLayout title={pageTitle} description={metaDescription}>
  <section class="page-hero">
    <div class="page-hero-inner">
      <p class="page-eyebrow">
        <span class="page-eyebrow-num">03</span>
        <span class="page-eyebrow-sep" aria-hidden="true">·</span>
        <span class="page-eyebrow-name">Books</span>
      </p>
      <h1 class="page-title">書架清單</h1>
      <hr class="page-title-rule" aria-hidden="true" />
      <p class="page-description" set:html={renderInlineMarkdown(pageDescription)} />
      <div class="page-search">
        <SearchBox placeholder="搜尋書名、作者…" variant="hero" />
      </div>
    </div>
  </section>

  {
    sortedBooks.length === 0 ? (
      <section class="empty-state">
        <div class="empty-state-inner">
          <p class="empty-state-eyebrow">尚未開放</p>
          <h2>書架清單正在編纂中</h2>
          <p>首批書目摘要正由 AI 心理學家 Agent 繆思生成、策展人薩約審校中。</p>
          <p>
            如果你有想推薦的書，請參考
            <a href="/contribute">貢獻指南</a>。
          </p>
        </div>
      </section>
    ) : (
      <>
        <section class="page-toolbar" aria-label="篩選">
          <div class="page-toolbar-inner">
            <div class="filter-group">
              <p class="filter-label">主題：</p>
              <ul class="filter-tags">
                {allTopicTags.map((tag) => (
                  <li>
                    <TagPill label={tag} variant="topic" size="sm" href={`/books?topic=${tag}`} />
                  </li>
                ))}
              </ul>
            </div>
            <div class="filter-group">
              <p class="filter-label">書類：</p>
              <ul class="filter-tags">
                {allBookTypes.map((t) => (
                  <li>
                    <TagPill label={t} variant="topic" size="sm" href={`/books?type=${t}`} />
                  </li>
                ))}
              </ul>
            </div>
            <div class="filter-group">
              <p class="filter-label">難度：</p>
              <ul class="filter-tags">
                {allDifficulties.map((d) => (
                  <li>
                    <TagPill label={d} variant="reader" size="sm" href={`/books?difficulty=${d}`} />
                  </li>
                ))}
              </ul>
            </div>
            {hasAnyZhTranslation && (
              <div class="filter-group">
                <p class="filter-label">中譯本：</p>
                <ul class="filter-tags">
                  <li>
                    <TagPill
                      label="有中譯本"
                      variant="status"
                      status="translated"
                      size="sm"
                      href="/books?zh=1"
                    />
                  </li>
                </ul>
              </div>
            )}
          </div>
        </section>

        <section class="entry-list-section">
          <ul class="book-list">
            {sortedBooks.map((entry, i) => (
              <li class="book-card">
                <a href={`/books/${entry.id}`}>
                  <span class="book-card-no" aria-hidden="true">№{(i + 1).toString().padStart(3, '0')}</span>
                  <header class="book-card-header">
                    <p class="book-card-meta">
                      <span class="book-card-year">{entry.data.year}</span>
                      <span class="book-card-publisher">{entry.data.publisher}</span>
                    </p>
                    <h2 class="book-card-title">
                      {entry.data.title}
                      {entry.data.title_zh && (
                        <span class="book-card-title-zh">{entry.data.title_zh}</span>
                      )}
                    </h2>
                    <p class="book-card-authors">{entry.data.author}</p>
                  </header>
                  <p
                    class="book-card-curator"
                    set:html={renderInlineMarkdown(entry.data.curator_note)}
                  />
                  <ul class="book-card-tags">
                    <li>
                      <TagPill label={entry.data.book_type} variant="topic" size="sm" />
                    </li>
                    <li>
                      <TagPill label={entry.data.difficulty} variant="reader" size="sm" />
                    </li>
                    {entry.data.has_zh_translation && (
                      <li>
                        <TagPill
                          label="有中譯本"
                          variant="status"
                          status="translated"
                          size="sm"
                        />
                      </li>
                    )}
                  </ul>
                </a>
              </li>
            ))}
          </ul>
        </section>
      </>
    )
  }
</BaseLayout>

<style>
  .page-hero {
    padding: var(--space-11) var(--space-5) var(--space-9);
    border-bottom: 1px solid var(--rule-fine);
  }

  .page-hero-inner {
    max-width: var(--content-width-index);
    margin: 0 auto;
  }

  /* Page Hero — V2 Polish */
  .page-eyebrow {
    font-family: var(--font-sans);
    font-size: var(--fs-eyebrow);
    text-transform: uppercase;
    letter-spacing: var(--ls-eyebrow);
    color: var(--accent-primary);
    margin: 0 0 var(--space-4);
    display: inline-flex;
    align-items: baseline;
    gap: 8px;
  }

  .page-eyebrow-num {
    font-family: var(--font-mono);
    font-weight: var(--fw-semibold);
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.04em;
  }

  .page-eyebrow-sep {
    color: var(--ink-disabled);
    font-weight: var(--fw-regular);
  }

  .page-eyebrow-name {
    font-weight: var(--fw-semibold);
  }

  .page-title {
    font-size: var(--fs-h1);
    font-weight: var(--fw-semibold);
    letter-spacing: var(--ls-h1);
    line-height: var(--lh-tight);
    margin: 0 0 var(--space-5);
  }

  .page-title-rule {
    width: 64px;
    height: 1px;
    background: var(--accent-primary);
    border: 0;
    margin: 0 0 var(--space-6);
  }

  .page-description {
    font-size: var(--fs-body);
    line-height: var(--lh-body);
    color: var(--ink-meta);
    margin: 0 0 var(--space-7);
    max-width: 65ch;
  }

  .page-description :global(strong) {
    color: var(--ink-heading);
    font-weight: var(--fw-semibold);
  }

  .page-search {
    max-width: 100%;
  }

  .page-toolbar {
    padding: var(--space-5);
    background: var(--bg-subtle);
    border-bottom: 1px solid var(--rule-fine);
  }

  .page-toolbar-inner {
    max-width: var(--content-width-index);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .filter-group {
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .filter-label {
    font-family: var(--font-sans);
    font-size: var(--fs-caption);
    color: var(--ink-meta);
    margin: 0;
    min-width: 5em;
  }

  .filter-tags {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .empty-state {
    padding: var(--space-12) var(--space-5);
  }

  .empty-state-inner {
    max-width: 60ch;
    margin: 0 auto;
    text-align: center;
  }

  .empty-state-eyebrow {
    font-family: var(--font-sans);
    font-size: var(--fs-eyebrow);
    text-transform: uppercase;
    letter-spacing: var(--ls-eyebrow);
    color: var(--ink-disabled);
    margin: 0 0 var(--space-4);
  }

  .empty-state h2 {
    font-size: var(--fs-h2);
    margin: 0 0 var(--space-5);
  }

  .empty-state p {
    color: var(--ink-meta);
  }

  .empty-state a {
    color: var(--accent-primary);
  }

  .entry-list-section {
    padding: var(--space-9) var(--space-5) var(--space-11);
  }

  .book-list {
    max-width: var(--content-width-index);
    margin: 0 auto;
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
    gap: var(--space-5);
  }

  /* ──────────────────────────────────────────────────────
     Book card — V2 Polish: D + 微 A
     ────────────────────────────────────────────────────── */
  .book-card a {
    position: relative;
    display: block;
    padding: var(--space-6) var(--space-7);
    background: var(--bg-elevated);
    border: 1px solid var(--rule-fine);
    border-radius: var(--radius-sm);
    text-decoration: none;
    color: var(--ink-body);
    height: 100%;
    overflow: hidden;
    transition: border-color 150ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .book-card a::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    bottom: 0;
    width: 0;
    background: var(--accent-primary);
    transition: width 200ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .book-card a:hover {
    border-color: var(--accent-primary);
  }

  .book-card a:hover::before {
    width: 3px;
  }

  .book-card a:focus-visible {
    outline: 2px solid var(--accent-primary);
    outline-offset: 2px;
  }

  .book-card-no {
    position: absolute;
    top: var(--space-4);
    right: var(--space-5);
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: var(--fw-medium);
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.06em;
    color: var(--ink-disabled);
    line-height: 1;
  }

  .book-card-header {
    padding-right: var(--space-8);
  }

  .book-card-meta {
    font-family: var(--font-sans);
    font-size: var(--fs-caption);
    color: var(--ink-meta);
    margin: 0 0 var(--space-2);
    display: flex;
    gap: var(--space-3);
    align-items: baseline;
  }

  .book-card-year {
    font-variant-numeric: tabular-nums;
    font-weight: var(--fw-semibold);
    color: var(--ink-body);
    letter-spacing: 0.02em;
  }

  .book-card-publisher {
    font-style: italic;
  }

  /* 主標題：英文 + 中文（雙行） */
  .book-card-title {
    font-size: var(--fs-h3);
    font-family: var(--font-serif);
    font-weight: var(--fw-semibold);
    margin: 0 0 var(--space-2);
    color: var(--ink-heading);
    letter-spacing: var(--ls-tight);
    line-height: var(--lh-heading);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  /* Underline grow on hover — 在英文主行下方畫 hairline（::after pseudo） */
  .book-card-title {
    position: relative;
    padding-bottom: 2px;
  }

  .book-card-title::after {
    content: '';
    position: absolute;
    left: 0;
    /* 對齊英文主行底線：line-height * fs-h3 * 0.95 ≈ 1.3 * 20px */
    top: calc(var(--fs-h3) * var(--lh-heading) - 1px);
    height: 1px;
    width: 0;
    background: var(--accent-primary);
    transition: width 200ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .book-card a:hover .book-card-title::after {
    width: 100%;
  }

  .book-card-title-zh {
    font-family: var(--font-sans);
    font-size: var(--fs-body-sm);
    color: var(--ink-meta);
    font-weight: var(--fw-regular);
  }

  .book-card-authors {
    font-family: var(--font-sans);
    font-size: var(--fs-body-sm);
    color: var(--ink-meta);
    margin: 0 0 var(--space-4);
  }

  .book-card-curator {
    font-size: var(--fs-body-sm);
    line-height: var(--lh-body);
    color: var(--ink-body);
    margin: 0 0 var(--space-4);
    border-left: 3px solid var(--accent-citation);
    padding-left: var(--space-4);
  }

  .book-card-tags {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  @media (prefers-reduced-motion: reduce) {
    .book-card a,
    .book-card a::before,
    .book-card-title::after {
      transition: none;
    }
  }
</style>
