---
/**
 * Counselors directory — Kink-friendly 諮商師（empty state）
 * v0.4.0 新建（schema v1.3）
 */

import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';

const allCounselors = await getCollection('counselors');
const sorted = allCounselors.sort((a, b) => a.data.name.localeCompare(b.data.name));

const pageTitle = '諮商資源 · Counselors';
const pageDescription =
  'Kink-friendly 諮商師 directory（自薦 + 審核制）。本目錄為對外公開的指路用途，不背書個人專業能力。';
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <section class="page-hero">
    <div class="page-hero-inner">
      <p class="page-eyebrow">
        <span class="page-eyebrow-num">06</span>
        <span class="page-eyebrow-sep" aria-hidden="true">·</span>
        <span class="page-eyebrow-name">Counselors</span>
      </p>
      <h1 class="page-title">諮商資源</h1>
      <hr class="page-title-rule" aria-hidden="true" />
      <p class="page-description">{pageDescription}</p>
    </div>
  </section>

  {
    sorted.length === 0 ? (
      <section class="empty-state">
        <div class="empty-state-inner">
          <p class="empty-state-eyebrow">尚未開放</p>
          <h2>諮商師 directory 待填</h2>
          <p>
            本目錄為 kink-friendly 諮商師 directory（自薦 + 審核制）。
            若你是諮商師、有 kink-friendly 工作經驗，並願意被列在站上，
            歡迎來信 <a href="mailto:curator@kinkref.org">curator@kinkref.org</a>。
          </p>
          <p>
            詳細收錄原則見
            <a
              href="https://github.com/NonTricker/kinkref_org/blob/main/content/counselors/README.md"
              target="_blank"
              rel="noopener noreferrer"
            >
              content/counselors/README.md
            </a>
            。
          </p>
        </div>
      </section>
    ) : (
      <section class="entry-list-section">
        <ul class="counselor-list">
          {sorted.map((entry) => (
            <li class="counselor-card">
              <article>
                <header>
                  <h2>{entry.data.name}</h2>
                  {entry.data.pronouns && <p class="pronouns">{entry.data.pronouns}</p>}
                </header>
                <p class="credentials">{entry.data.credentials.join('、')}</p>
                <p class="location">{entry.data.location}</p>
                <p class="modes">
                  {entry.data.service_modes.join(' / ')} · {entry.data.languages.join(' / ')}
                </p>
                <p class="statement">{entry.data.kink_friendly_statement.slice(0, 120)}…</p>
                {entry.data.contact_email && (
                  <p>
                    <a href={`mailto:${entry.data.contact_email}`}>{entry.data.contact_email}</a>
                  </p>
                )}
              </article>
            </li>
          ))}
        </ul>
      </section>
    )
  }
</BaseLayout>

<style>
  .page-hero {
    padding: var(--space-11) var(--space-5) var(--space-9);
    border-bottom: 1px solid var(--rule-fine);
  }
  .page-hero-inner {
    max-width: var(--content-width-index);
    margin: 0 auto;
  }
  .page-eyebrow {
    font-family: var(--font-sans);
    font-size: var(--fs-eyebrow);
    text-transform: uppercase;
    letter-spacing: var(--ls-eyebrow);
    color: var(--accent-primary);
    margin: 0 0 var(--space-4);
    display: inline-flex;
    align-items: baseline;
    gap: 8px;
  }
  .page-eyebrow-num {
    font-family: var(--font-mono);
    font-weight: var(--fw-semibold);
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.04em;
  }
  .page-eyebrow-sep { color: var(--ink-disabled); }
  .page-eyebrow-name { font-weight: var(--fw-semibold); }
  .page-title {
    font-size: var(--fs-h1);
    font-weight: var(--fw-semibold);
    line-height: var(--lh-tight);
    margin: 0 0 var(--space-5);
  }
  .page-title-rule {
    width: 64px;
    height: 1px;
    background: var(--accent-primary);
    border: 0;
    margin: 0 0 var(--space-6);
  }
  .page-description {
    font-size: var(--fs-body);
    line-height: var(--lh-body);
    color: var(--ink-meta);
    margin: 0;
  }
  .empty-state { padding: var(--space-12) var(--space-5); }
  .empty-state-inner {
    max-width: var(--content-width-prose);
    margin: 0 auto;
    text-align: center;
  }
  .empty-state-eyebrow {
    font-family: var(--font-sans);
    font-size: var(--fs-eyebrow);
    text-transform: uppercase;
    letter-spacing: var(--ls-eyebrow);
    color: var(--ink-disabled);
    margin: 0 0 var(--space-4);
  }
  .empty-state h2 {
    font-size: var(--fs-h2);
    margin: 0 0 var(--space-5);
  }
  .empty-state p {
    color: var(--ink-meta);
    line-height: var(--lh-body);
    margin: 0 0 var(--space-4);
  }
  .empty-state a { color: var(--accent-primary); }

  .entry-list-section {
    padding: var(--space-9) var(--space-5) var(--space-11);
  }
  .counselor-list {
    max-width: var(--content-width-index);
    margin: 0 auto;
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
    gap: var(--space-5);
  }
  .counselor-card article {
    padding: var(--space-5) var(--space-6);
    background: var(--bg-elevated);
    border: 1px solid var(--rule-fine);
    border-left: 3px solid var(--accent-primary);
    border-radius: var(--radius-sm);
  }
  .counselor-card h2 {
    font-size: var(--fs-h3);
    margin: 0 0 var(--space-2);
  }
  .pronouns, .credentials, .location, .modes {
    font-family: var(--font-sans);
    font-size: var(--fs-caption);
    color: var(--ink-meta);
    margin: 0 0 var(--space-2);
  }
  .statement {
    font-size: var(--fs-body-sm);
    line-height: var(--lh-body);
    color: var(--ink-body);
    margin: var(--space-3) 0;
  }
</style>
