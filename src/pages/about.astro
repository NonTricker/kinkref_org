---
/**
 * About — 站方立場、治理、聯絡
 *
 * v0.2.0 / schema 1.2：
 * - §編輯立場 加 AI-augmented 透明
 * - §治理模型 → 角色 重寫為「站方角色（三角色 card）」+「外部貢獻者」
 *   三角色：kinkref（站方）/ 繆思 Muse（AI 心理學家 Agent）/ 策展人薩約（人類審校）
 * - §聯絡 改用 curator@kinkref.org + GitHub Security Advisory
 * - §版本 升 v0.2.0
 *
 * 內容來源：靈範師（Muse）ABOUT_CONTENT_V1.2.md
 * 整合：織法者（紬）— 2026-05-02
 */

import BaseLayout from '@layouts/BaseLayout.astro';

const pageTitle = '關於 · About';
const description = 'kinkref.org 的定位、治理模型、編輯立場與聯絡方式。';
---

<BaseLayout title={pageTitle} description={description}>
  <article class="about-page">
    <header class="about-header">
      <p class="page-eyebrow">About</p>
      <h1>關於 Kink Reference</h1>
      <p class="about-tagline">
        中文 BDSM 學術文獻策展與術語索引。<br />
        Curating BDSM scholarship for the Traditional Chinese reading public.
      </p>
    </header>

    <section class="about-section" id="position">
      <h2>定位</h2>
      <p>
        本站是<strong>轉譯派 (Translator-Curator)</strong>—— 英文 BDSM
        學術文獻的中文摘要與索引站。台灣中文圈完全沒有結構化的 BDSM
        學術入口，本站填補這個缺口。
      </p>
      <p>本站不是：</p>
      <ul>
        <li>介紹站（不做通識教育）</li>
        <li>橋樑站（不做圈內外橋接）</li>
        <li>論壇（不做社群互動）</li>
        <li>全域知識庫（不做全方位百科）</li>
      </ul>
      <p>
        完整定位見
        <a href="https://github.com/NonTricker/kinkref_org/blob/main/docs/PROJECT_SPEC.md" target="_blank" rel="noopener noreferrer">PROJECT_SPEC.md</a>。
      </p>
    </section>

    <section class="about-section" id="editorial">
      <h2>編輯立場</h2>
      <p>本站秉持以下核心原則：</p>
      <ul>
        <li>
          <strong>學術 rigor 優先</strong>：所有條目附引用、DOI、出版年。
          區分共識、單一研究、爭議三類斷言。
        </li>
        <li>
          <strong>中性敘事</strong>：不評價哪種傾向「正確」或「進階」。
          不使用「真正的⋯應該」「只有⋯才算是」等規範性語言。
        </li>
        <li>
          <strong>翻譯透明</strong>：機翻初稿 + 人工校對標示完整 commit history。
        </li>
        <li>
          <strong>AI-augmented 透明</strong>：本站條目初稿由站方 AI 心理學家 Agent
          「繆思（Muse）」生成，所有條目透明標示 contributor 與 contributor_note。
          策展人對實質介入的條目以「策展人薩約」署名審校。詳見下方
          <a href="#governance">治理模型 → 站方角色</a>。
        </li>
        <li>
          <strong>明確負面清單</strong>：不做安全操作指引、不做場地推薦、
          不收任何形式贊助、不涉及未成年內容。
        </li>
      </ul>
    </section>

    <section class="about-section" id="governance">
      <h2>治理模型</h2>

      <h3>站方角色</h3>
      <p class="role-intro">
        站方由三個角色協作運轉：站方品牌（kinkref）、AI 初稿 Agent（繆思）、人類策展人（薩約）。
        三者分工透明、責任明確。
      </p>
      <ol class="role-stack" aria-label="站方三角色">
        <li class="role-card">
          <p class="role-card-tag">Brand · 站方品牌</p>
          <h4 class="role-card-name">kinkref</h4>
          <p class="role-card-desc">
            站方 brand 識別。所有條目的 <code>contributor</code> 欄位統一填
            <code>kinkref</code>，作為條目的官方歸屬。讀者引用本站內容時，
            作者可標 <code>kinkref.org</code> 或站方主編。
          </p>
        </li>
        <li class="role-card">
          <p class="role-card-tag">Agent · AI 心理學家</p>
          <h4 class="role-card-name">繆思 Muse</h4>
          <p class="role-card-desc">
            站方建置的專責 AI Agent，負責條目初稿生成、跨條目一致性維護、
            術語辨析整理。對讀者完全透明—— 所有條目的 <code>contributor_note</code>
            明確標示「本條目由 AI 心理學家 Agent 繆思（Muse）生成」。
            繆思不假裝為人工撰寫、不偽裝為人類專家，所有觀點均經人類策展原則框架約束。
          </p>
        </li>
        <li class="role-card">
          <p class="role-card-tag">Curator · 人類策展人</p>
          <h4 class="role-card-name">策展人薩約</h4>
          <p class="role-card-desc">
            人類策展人，負責本站的內容戰略、品質把關、圈內視角校正。
            對於主編實質介入過的條目（翻譯哲學決策、圈內微分洞察、敏感議題的審校），
            條目會額外標示 <code>reviewer: 策展人薩約</code>。
          </p>
        </li>
      </ol>

      <h3>外部貢獻者角色</h3>
      <ul>
        <li>
          <strong>貢獻者</strong>：透過 PR 或 email 投稿術語、書目、論文摘要、翻譯。
          詳見 <a href="https://github.com/NonTricker/kinkref_org/blob/main/CONTRIBUTING.md" target="_blank" rel="noopener noreferrer">CONTRIBUTING.md</a>。
        </li>
        <li>
          <strong>審校者</strong>：協助方法論段落或翻譯品質的人工複審。
          可由策展人擔任，也歡迎具備相關專業的圈內貢獻者。
        </li>
      </ul>

      <h3>開放投稿區</h3>
      <p>歡迎社群提交 PR：</p>
      <ul>
        <li>術語表新增 / 中文定義補充 / 辨析</li>
        <li>書目新增 / 書摘撰寫</li>
        <li>論文新增 / 摘要撰寫 / 翻譯勘誤</li>
        <li>引用格式修正</li>
      </ul>

      <h3>主編鎖定區</h3>
      <p>以下內容由主編獨立維護，不接受外部修改型 PR：</p>
      <ul>
        <li>窒息類項目（學界共識：不存在安全做法，立場硬性鎖定）</li>
        <li>法律章節（需專業審核）</li>
        <li>未成年保護聲明（零爭議區）</li>
        <li>站方立場 / 治理說明</li>
        <li>任何「安全操作指引」性質內容</li>
      </ul>
    </section>

    <section class="about-section" id="license">
      <h2>授權</h2>
      <p>
        本站內容採
        <a href="https://creativecommons.org/licenses/by-sa/4.0/" rel="license">
          CC BY-SA 4.0
        </a>
        授權。
      </p>
      <ul>
        <li>可以自由引用、改作、傳播</li>
        <li>商業使用也可以</li>
        <li>必須註明來源</li>
        <li>改作後須以相同授權釋出</li>
      </ul>
    </section>

    <section class="about-section" id="contact">
      <h2>聯絡</h2>
      <p>
        <strong>投稿信箱</strong>：寄信至策展人信箱
        <a href="mailto:curator@kinkref.org">curator@kinkref.org</a>。
        圈名、匿名、一次性讀者皆歡迎。
      </p>
      <p>
        <strong>內容問題</strong>（事實錯誤、引用問題、範圍爭議）：請使用
        <a href="https://github.com/NonTricker/kinkref_org/issues" target="_blank" rel="noopener noreferrer">GitHub Issues</a>。
      </p>
      <p>
        <strong>安全回報</strong>：請使用
        <a href="https://github.com/NonTricker/kinkref_org/security/advisories/new" target="_blank" rel="noopener noreferrer">GitHub Security Advisory</a>
        （私密回報通道）；亦可參考
        <a href="https://github.com/NonTricker/kinkref_org/blob/main/SECURITY.md" target="_blank" rel="noopener noreferrer">SECURITY.md</a>。
      </p>
    </section>

    <section class="about-section" id="version">
      <h2>版本</h2>
      <ul class="version-list">
        <li><span>站台版本</span><span>v0.4.0</span></li>
        <li><span>Schema 版本</span><span>1.4</span></li>
        <li><span>建置基底</span><span>Astro 6.x · 純 CSS Variables</span></li>
        <li><span>授權</span><span>CC BY-SA 4.0</span></li>
      </ul>
    </section>
  </article>
</BaseLayout>

<style>
  /* About 採 index 寬度（1024px）。內容段落不再限制 65ch，
     對齊 v0.3.7「全頁一致」的執政官指示。 */
  .about-page {
    max-width: var(--content-width-index);
    margin: 0 auto;
    padding: var(--space-11) var(--space-5) var(--space-12);
  }

  .about-header {
    margin-bottom: var(--space-11);
    padding-bottom: var(--space-7);
    border-bottom: 1px solid var(--rule-fine);
  }

  .page-eyebrow {
    font-family: var(--font-sans);
    font-size: var(--fs-eyebrow);
    text-transform: uppercase;
    letter-spacing: var(--ls-eyebrow);
    color: var(--accent-primary);
    margin: 0 0 var(--space-3);
  }

  .about-header h1 {
    font-size: var(--fs-h1);
    margin: 0 0 var(--space-5);
  }

  .about-tagline {
    font-size: var(--fs-body);
    color: var(--ink-meta);
    line-height: var(--lh-body);
    margin: 0;
  }

  .about-section {
    margin-bottom: var(--space-11);
    scroll-margin-top: 80px;
  }

  .about-section h2 {
    font-size: var(--fs-h2);
    margin: 0 0 var(--space-5);
  }

  .about-section h3 {
    font-size: var(--fs-h3);
    margin-top: var(--space-7);
    margin-bottom: var(--space-4);
  }

  .about-section h4 {
    font-size: var(--fs-h4);
    margin: 0 0 var(--space-3);
  }

  .about-section ul {
    padding-left: var(--space-6);
  }

  .about-section li {
    margin-bottom: var(--space-2);
    line-height: var(--lh-body);
  }

  .about-section a {
    color: var(--accent-primary);
  }

  .about-section code {
    font-family: var(--font-mono);
    font-size: 0.92em;
    color: var(--accent-citation);
    background: var(--bg-subtle);
    padding: 0.1em 0.35em;
    border-radius: 2px;
  }

  /* 站方三角色 — 三欄卡片（DESIGN.md §6 Level 5 浮起層） */
  .role-intro {
    color: var(--ink-meta);
    font-size: var(--fs-body-sm);
    margin: var(--space-3) 0 var(--space-5);
  }

  .role-stack {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-7);
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-5);
  }

  .role-card {
    background: var(--bg-elevated);
    border: 1px solid var(--rule-fine);
    border-radius: var(--radius-sm);
    padding: var(--space-5) var(--space-5) var(--space-6);
    margin: 0;
  }

  .role-card-tag {
    font-family: var(--font-sans);
    font-size: var(--fs-eyebrow);
    text-transform: uppercase;
    letter-spacing: var(--ls-eyebrow);
    color: var(--ink-meta);
    margin: 0 0 var(--space-2);
  }

  .role-card-name {
    font-family: var(--font-serif);
    font-weight: var(--fw-semibold);
    color: var(--accent-primary);
    margin: 0 0 var(--space-3);
    padding-bottom: var(--space-2);
    border-bottom: 1px solid var(--rule-fine);
  }

  .role-card-desc {
    font-size: var(--fs-body-sm);
    line-height: var(--lh-body);
    margin: 0;
    color: var(--ink-body);
  }

  @media (max-width: 720px) {
    .role-stack {
      grid-template-columns: 1fr;
    }
  }

  .version-list {
    list-style: none;
    padding: 0;
    margin: 0;
    border: 1px solid var(--rule-fine);
    border-radius: var(--radius-sm);
    background: var(--bg-subtle);
  }

  .version-list li {
    display: flex;
    justify-content: space-between;
    padding: var(--space-3) var(--space-5);
    margin: 0;
    border-bottom: 1px solid var(--rule-fine);
    font-family: var(--font-sans);
    font-size: var(--fs-body-sm);
  }

  .version-list li:last-child {
    border-bottom: 0;
  }

  .version-list li > span:first-child {
    color: var(--ink-meta);
  }

  .version-list li > span:last-child {
    font-family: var(--font-mono);
    font-size: var(--fs-mono);
    color: var(--ink-body);
  }
</style>
