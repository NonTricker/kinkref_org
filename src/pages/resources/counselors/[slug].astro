---
/**
 * Counselor detail page — `/resources/counselors/[slug]`
 *
 * 律法家政策（2026-05-08）：
 *   - 證號為當事人主動提供才列；未列 ≠ 未具備資格
 *   - 站方僅形式審查（具名 + 執業資格證明），不背書專業能力
 *   - 內部 PII（contact_phone_internal、未經同意的補充身份）絕不渲染
 *   - 每條目附「自薦 + 同意收錄」+ 退出機制聲明
 *
 * URL 結構：/resources/counselors/{slug}
 * 麵包屑：首頁 / 資源 / 心理諮商 / [姓名]
 */

import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const all = await getCollection('counselors');
  return all.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'counselors'>;
}

const { entry } = Astro.props;
const data = entry.data;

const SITE_URL = 'https://kinkref.org';
const pageURL = `${SITE_URL}/resources/counselors/${entry.id}`;

// SEO（脈流師 WORKORDER #004 §3）
// Title: 動態 credentials 對應 query「BDSM 諮商師 / BDSM 友善心理師 / kink 諮商」
//        加 location 接住地區 long-tail（「台北 BDSM 諮商」「高雄 kink 諮商」）
// Description: 加 "BDSM 友善" / "kink-friendly" / specialty 提升 entity match
const credForTitle = data.credentials[0] ?? '助人工作者';
const pageTitle = `${data.name}｜BDSM 友善${credForTitle}（${data.location}）`;

const specialtyShort = data.specialty.slice(0, 2).join('、');
const credText = data.credentials.join('、');
const institutionPart = data.institution ? `・${data.institution}` : '';
const description = `${data.name}（${credText}）${institutionPart}・${data.location}。BDSM 友善（kink-friendly）${credForTitle}，擅長 ${specialtyShort}。經自薦同意收錄｜kinkref.org BDSM 友善諮商師名單`;

// JSON-LD: ProfilePage（schema.org/ProfilePage）
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ProfilePage',
  '@id': `${pageURL}#profile`,
  url: pageURL,
  inLanguage: 'zh-Hant-TW',
  mainEntity: {
    '@type': 'Person',
    name: data.name,
    jobTitle: data.credentials.join('、'),
    ...(data.institution && {
      worksFor: { '@type': 'Organization', name: data.institution },
    }),
    ...(data.contact_website && { url: data.contact_website }),
  },
};

// re-verify 提示日期
const nextVerifyDate = new Date(data.last_verified);
nextVerifyDate.setFullYear(nextVerifyDate.getFullYear() + 1);

const dateFmt = (d: Date) =>
  new Intl.DateTimeFormat('zh-TW', {
    year: 'numeric',
    month: '2-digit',
    day: '2-digit',
  }).format(d);

// Source 顯示文字
const sourceLabel: Record<string, string> = {
  禁羈名單: '經臺灣 BDSMer 友善之助人工作者資源網認證',
  自薦: '當事人自薦並同意收錄',
};
---

<BaseLayout title={pageTitle} description={description} jsonLd={jsonLd}>
  <article class="counselor">
    <nav class="counselor-breadcrumb" aria-label="麵包屑">
      <a href="/">首頁</a>
      <span aria-hidden="true">/</span>
      <a href="/resources">資源</a>
      <span aria-hidden="true">/</span>
      <a href="/resources#counselors">心理諮商</a>
      <span aria-hidden="true">/</span>
      <span class="counselor-breadcrumb-current">{data.name}</span>
    </nav>

    <header class="counselor-header">
      <p class="counselor-eyebrow">{data.credentials.join('、')}</p>
      <h1 class="counselor-name">{data.name}</h1>
      <p class="counselor-meta">
        {data.institution && <><span>{data.institution}</span><span aria-hidden="true"> · </span></>}
        <span>{data.location}</span>
      </p>
      <div class="counselor-badges">
        {data.referral_source && (
          <span class="counselor-badge counselor-badge--source">
            {sourceLabel[data.referral_source] ?? data.referral_source}
          </span>
        )}
        {data.pro_bono?.available && (
          <span class="counselor-badge counselor-badge--probono">
            ✓ {data.pro_bono.note ?? '可提供公益服務'}
          </span>
        )}
      </div>
    </header>

    {/* 邀請語 / 自介（v1.6） — 保留本人原話 */}
    {data.introduction && (
      <section class="counselor-section counselor-intro" aria-label="自介">
        <p>{data.introduction}</p>
      </section>
    )}

    {/* 專業資格 — 證號（條件渲染） */}
    {data.licenses && data.licenses.length > 0 && (
      <section class="counselor-section" aria-label="專業資格">
        <h2>專業資格</h2>
        <ul class="counselor-licenses">
          {data.licenses.map((l) => <li>{l}</li>)}
        </ul>
        <p class="counselor-license-note">
          證號為當事人主動提供。未列出證號不代表未具備資格——讀者可向衛福部全國醫事資訊系統查證任何已執業心理師。
        </p>
      </section>
    )}

    {/* 額外協會身份（v1.5 — 必須本人明確同意才填） */}
    {data.affiliation_extra && data.affiliation_extra.length > 0 && (
      <section class="counselor-section" aria-label="其他身份">
        <h2>其他身份</h2>
        <ul class="counselor-affiliations">
          {data.affiliation_extra.map((a) => <li>{a}</li>)}
        </ul>
      </section>
    )}

    {/* 擅長議題 */}
    <section class="counselor-section" aria-label="擅長議題">
      <h2>擅長議題</h2>
      <ul class="counselor-specialty">
        {data.specialty.map((s) => <li>{s}</li>)}
      </ul>
      {data.kink_friendly_statement && (
        <p class="counselor-statement">{data.kink_friendly_statement}</p>
      )}
    </section>

    {/* 服務與語言 */}
    <section class="counselor-section" aria-label="服務模式">
      <h2>服務模式</h2>
      <dl class="counselor-meta-grid">
        <div>
          <dt>服務形式</dt>
          <dd>
            {data.service_modes.map((m, i) => (
              <>
                {i > 0 && <span aria-hidden="true"> · </span>}
                <span>{m === 'in-person' ? '實體' : m === 'online' ? '線上' : '混合'}</span>
              </>
            ))}
          </dd>
        </div>
        {data.languages && data.languages.length > 0 && !(data.languages.length === 1 && data.languages[0] === '中文') && (
          <div>
            <dt>使用語言</dt>
            <dd>{data.languages.join('、')}</dd>
          </div>
        )}
      </dl>
    </section>

    {/* 預約（v1.6 擴：website + email + phone + extras 多管道） */}
    <section class="counselor-section counselor-cta" aria-label="預約管道">
      <h2>預約管道</h2>
      {data.contact_method_label && !data.contact_extras && (
        <p class="counselor-contact-label">{data.contact_method_label}</p>
      )}
      <div class="counselor-cta-buttons">
        {data.contact_website && (
          <a
            href={data.contact_website}
            class="counselor-cta-button counselor-cta-button--primary"
            target="_blank"
            rel="noopener noreferrer"
          >
            前往預約頁面 →
          </a>
        )}
        {data.contact_email && (
          <a
            href={`mailto:${data.contact_email}`}
            class="counselor-cta-button"
          >
            ✉ {data.contact_email}
          </a>
        )}
        {data.contact_phone && (
          <a
            href={`tel:${data.contact_phone.replace(/[^\d+]/g, '')}`}
            class="counselor-cta-button"
          >
            ☎ {data.contact_phone}
          </a>
        )}
        {data.contact_extras?.map((extra) =>
          extra.url ? (
            <a
              href={extra.url}
              class="counselor-cta-button"
              target="_blank"
              rel="noopener noreferrer"
            >
              {extra.label}
            </a>
          ) : (
            <span class="counselor-cta-button counselor-cta-button--static">
              {extra.label}
            </span>
          )
        )}
      </div>
    </section>

    {/* 公益服務（v1.6） */}
    {data.pro_bono?.available && (
      <section class="counselor-section counselor-probono" aria-label="公益服務">
        <h2>公益服務</h2>
        {data.pro_bono.note && (
          <p class="counselor-probono-note">{data.pro_bono.note}</p>
        )}
        {data.pro_bono.programs && data.pro_bono.programs.length > 0 && (
          <ul class="counselor-probono-programs">
            {data.pro_bono.programs.map((p) => <li>{p}</li>)}
          </ul>
        )}
        <p class="counselor-probono-disclaimer">
          公益方案細節與適用條件請洽心理師或所屬機構。
        </p>
      </section>
    )}

    {/* 更多資源 — 交叉導流（脈流師 WORKORDER #004 §4.1） */}
    <section class="counselor-related" aria-label="更多資源">
      <h2>更多資源</h2>
      <ul>
        <li>
          <a href="/guides/counselors">BDSM 友善助人者完整名單 →</a>
          <span class="counselor-related-desc">含諮商心理師、臨床心理師、社工師、精神科醫師按性質分組</span>
        </li>
        <li>
          <a href="/guides/psychology">BDSM 與心理學閱讀指南</a>
          <span class="counselor-related-desc">去病理化、意識狀態、依附理論</span>
        </li>
        <li>
          <a href="/resources#counselors">回外部資源總覽</a>
        </li>
      </ul>
    </section>

    {/* 站方聲明 */}
    <footer class="counselor-footer" aria-label="站方聲明與驗證資訊">
      <ul class="counselor-disclaimer">
        <li>本站不對個人專業能力進行排名或推薦。</li>
        <li>本條目為「自薦 + 同意收錄」性質——當事人可隨時來信修改或退出。</li>
        <li>站方僅形式審查（具名 + 執業資格），不背書服務品質。</li>
      </ul>

      <dl class="counselor-verify">
        <div>
          <dt>最後驗證</dt>
          <dd><time datetime={data.last_verified.toISOString()}>{dateFmt(data.last_verified)}</time></dd>
        </div>
        <div>
          <dt>下次驗證</dt>
          <dd><time datetime={nextVerifyDate.toISOString()}>{dateFmt(nextVerifyDate)}</time></dd>
        </div>
      </dl>

      <p class="counselor-back">
        <a href="/resources#counselors">← 回 心理諮商資源列表</a>
      </p>
    </footer>
  </article>
</BaseLayout>

<style>
  .counselor {
    max-width: var(--content-width-prose);
    margin: 0 auto;
    padding: var(--space-9) var(--space-5) var(--space-11);
  }

  .counselor-breadcrumb {
    font-family: var(--font-sans);
    font-size: var(--fs-caption);
    color: var(--ink-meta);
    margin-bottom: var(--space-7);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    align-items: center;
  }

  .counselor-breadcrumb a {
    color: var(--ink-meta);
    text-decoration: none;
    transition: var(--transition-color);
  }

  .counselor-breadcrumb a:hover {
    color: var(--accent-primary);
  }

  .counselor-breadcrumb-current {
    color: var(--ink-body);
  }

  /* Header */
  .counselor-header {
    margin-bottom: var(--space-9);
    padding-bottom: var(--space-7);
    border-bottom: 1px solid var(--rule-fine);
  }

  .counselor-eyebrow {
    font-family: var(--font-sans);
    font-size: var(--fs-eyebrow);
    text-transform: uppercase;
    letter-spacing: var(--ls-eyebrow);
    color: var(--accent-primary);
    margin: 0 0 var(--space-3);
  }

  .counselor-name {
    font-family: var(--font-serif);
    font-size: var(--fs-h1);
    font-weight: var(--fw-semibold);
    line-height: var(--lh-tight);
    color: var(--ink-heading);
    margin: 0 0 var(--space-3);
  }

  .counselor-meta {
    font-family: var(--font-sans);
    font-size: var(--fs-body);
    color: var(--ink-meta);
    margin: 0 0 var(--space-4);
  }

  /* v1.6: badge bar — 取代舊的單一 source-badge，可容納多種 badge */
  .counselor-badges {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin: 0;
  }

  .counselor-badge {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: var(--fs-caption);
    border-radius: var(--radius-pill);
    padding: var(--space-1) var(--space-3);
    margin: 0;
    border: 1px solid var(--rule-fine);
    background: var(--bg-subtle);
  }

  .counselor-badge--source {
    color: var(--accent-primary);
  }

  .counselor-badge--probono {
    color: var(--accent-citation);
    border-color: color-mix(in srgb, var(--accent-citation) 40%, transparent);
    background: color-mix(in srgb, var(--accent-citation) 8%, var(--bg-subtle));
  }

  /* v1.6: 邀請語 / 自介 — 用 serif 親切質感，左側書脊作為設計引號 */
  .counselor-intro {
    padding: var(--space-5) var(--space-7);
    background: color-mix(in srgb, var(--accent-primary) 4%, var(--bg-subtle));
    border-left: 3px solid var(--accent-primary);
    border-radius: var(--radius-sm);
  }

  .counselor-intro p {
    font-family: var(--font-serif);
    font-size: var(--fs-body);
    line-height: 1.8;
    color: var(--ink-body);
    margin: 0;
    white-space: pre-wrap;
  }

  /* v1.6: 公益服務 section */
  .counselor-probono {
    padding: var(--space-5) var(--space-7);
    background: color-mix(in srgb, var(--accent-citation) 6%, var(--bg-subtle));
    border-radius: var(--radius-sm);
  }

  .counselor-probono-note {
    font-family: var(--font-sans);
    font-size: var(--fs-body);
    color: var(--ink-body);
    margin: 0 0 var(--space-3);
  }

  .counselor-probono-programs {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-3);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .counselor-probono-programs li {
    font-family: var(--font-sans);
    font-size: var(--fs-body-sm);
    color: var(--ink-body);
    padding-left: var(--space-4);
    position: relative;
  }

  .counselor-probono-programs li::before {
    content: '·';
    position: absolute;
    left: var(--space-2);
    color: var(--accent-citation);
    font-weight: var(--fw-semibold);
  }

  .counselor-probono-disclaimer {
    font-family: var(--font-sans);
    font-size: var(--fs-caption);
    color: var(--ink-meta);
    line-height: 1.6;
    margin: 0;
    padding-top: var(--space-3);
    border-top: 1px solid var(--rule-fine);
  }

  /* v1.6: 預約區的 static label（沒 url 的 extras 顯示） */
  .counselor-cta-button--static {
    cursor: default;
    color: var(--ink-meta);
  }
  .counselor-cta-button--static:hover {
    border-color: var(--rule-fine);
    color: var(--ink-meta);
  }

  /* Sections */
  .counselor-section {
    margin-bottom: var(--space-7);
  }

  .counselor-section h2 {
    font-family: var(--font-serif);
    font-size: var(--fs-h3);
    font-weight: var(--fw-semibold);
    color: var(--ink-heading);
    margin: 0 0 var(--space-4);
  }

  .counselor-licenses,
  .counselor-affiliations {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-3);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .counselor-licenses li,
  .counselor-affiliations li {
    font-family: var(--font-mono);
    font-size: var(--fs-body-sm);
    color: var(--ink-body);
    padding: var(--space-2) var(--space-4);
    background: var(--bg-subtle);
    border-left: 2px solid var(--accent-primary);
    border-radius: 2px;
  }

  .counselor-license-note {
    font-family: var(--font-sans);
    font-size: var(--fs-caption);
    color: var(--ink-meta);
    line-height: 1.6;
    margin: var(--space-3) 0 0;
  }

  .counselor-specialty {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-4);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .counselor-specialty li {
    font-family: var(--font-sans);
    font-size: var(--fs-body-sm);
    color: var(--ink-body);
    padding: var(--space-1) var(--space-3);
    background: var(--bg-subtle);
    border: 1px solid var(--rule-fine);
    border-radius: var(--radius-pill);
  }

  .counselor-statement {
    font-family: var(--font-serif);
    font-size: var(--fs-body);
    line-height: var(--lh-body);
    color: var(--ink-body);
    margin: 0;
    padding: var(--space-4) var(--space-5);
    background: var(--bg-subtle);
    border-left: 2px solid var(--accent-primary);
    border-radius: 2px;
  }

  /* Meta grid (服務形式 + 語言) */
  .counselor-meta-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: var(--space-5);
    margin: 0;
  }

  .counselor-meta-grid > div {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .counselor-meta-grid dt {
    font-family: var(--font-sans);
    font-size: var(--fs-caption);
    text-transform: uppercase;
    letter-spacing: var(--ls-eyebrow);
    color: var(--ink-meta);
  }

  .counselor-meta-grid dd {
    font-family: var(--font-sans);
    font-size: var(--fs-body);
    color: var(--ink-body);
    margin: 0;
  }

  /* CTA */
  .counselor-cta {
    background: var(--bg-subtle);
    padding: var(--space-7);
    border-radius: var(--radius-md);
  }

  .counselor-contact-label {
    font-family: var(--font-sans);
    font-size: var(--fs-body-sm);
    color: var(--ink-body);
    margin: 0 0 var(--space-4);
  }

  .counselor-cta-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .counselor-cta-button {
    display: inline-block;
    padding: var(--space-3) var(--space-5);
    font-family: var(--font-sans);
    font-size: var(--fs-body-sm);
    font-weight: var(--fw-medium);
    text-decoration: none;
    border-radius: var(--radius-sm);
    border: 1px solid var(--rule-fine);
    color: var(--ink-body);
    background: var(--bg-elevated);
    transition: var(--transition-color);
    word-break: break-all;
  }

  .counselor-cta-button:hover {
    border-color: var(--accent-primary);
    color: var(--accent-primary);
  }

  .counselor-cta-button--primary {
    background: var(--accent-primary);
    color: var(--bg-base);
    border-color: var(--accent-primary);
  }

  .counselor-cta-button--primary:hover {
    background: var(--bg-base);
    color: var(--accent-primary);
  }

  /* Footer 站方聲明 */
  /* v1.7: 交叉導流 — 連回 /guides/counselors pillar + 相關 guide */
  .counselor-related {
    margin-top: var(--space-9);
    padding-top: var(--space-7);
    border-top: 1px solid var(--rule-fine);
  }
  .counselor-related h2 {
    font-family: var(--font-serif);
    font-size: var(--fs-h3);
    font-weight: var(--fw-semibold);
    color: var(--ink-heading);
    margin: 0 0 var(--space-4);
  }
  .counselor-related ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .counselor-related li {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }
  .counselor-related a {
    font-family: var(--font-sans);
    font-size: var(--fs-body-sm);
    font-weight: var(--fw-medium);
    color: var(--accent-primary);
    text-decoration: none;
  }
  .counselor-related a:hover {
    text-decoration: underline;
  }
  .counselor-related-desc {
    font-family: var(--font-sans);
    font-size: var(--fs-caption);
    color: var(--ink-meta);
  }

  .counselor-footer {
    margin-top: var(--space-11);
    padding-top: var(--space-7);
    border-top: 1px solid var(--rule-fine);
  }

  .counselor-disclaimer {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-7);
    font-family: var(--font-sans);
    font-size: var(--fs-caption);
    color: var(--ink-meta);
    line-height: 1.7;
  }

  .counselor-disclaimer li {
    margin-bottom: var(--space-2);
    padding-left: var(--space-4);
    position: relative;
  }

  .counselor-disclaimer li::before {
