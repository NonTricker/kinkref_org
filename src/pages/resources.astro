const T_MEDICAL = `主旨：[醫師/診所自薦] 您的姓名/化名

我是 ______（姓名/化名），願意公開列在 kinkref.org 醫療資源頁。

資格類型：（醫師 / 診所）
醫師字號或診所統編：
執業地點（縣市）：
聯絡 email（僅供站方定期確認用，不公開）：
提供的 kink-friendly 服務說明（50-200 字）：`;

const applyConfigs = {
  counselors: {
    title: '心理資源',
    applyType: '助人工作者自薦',
    criteria: [
      '具備以下專業資格之一：諮商心理師 / 臨床心理師 / 精神科醫師 / 社工師（含醫務社工、社福機構、家暴防治等）',
      '在正式執業助人單位服務：諮商所 / 醫療院所 / 社福機構 / NGO / 大學諮商中心 / 學校輔導體系等（自由執業者另經個別審查，須提供執照字號 verify）',
      '明確同意被列在站上（listing_consent: true）',
      '具 kink-friendly 工作經驗或受過相關訓練',
