---

<BaseLayout title={pageTitle} description={pageDescription}>
  <section class="page-hero">
    <div class="page-hero-inner">
      <p class="page-eyebrow">
        <span class="page-eyebrow-num">06</span>
        <span class="page-eyebrow-sep" aria-hidden="true">·</span>
        <span class="page-eyebrow-name">Resources</span>
      </p>
      <h1 class="page-title">資源</h1>
      <hr class="page-title-rule" aria-hidden="true" />
      <p class="page-description">{pageDescription}</p>
      <p class="page-description-en" lang="en">External resources — crisis hotlines, kink-aware therapists, legal aid, campus groups, and medical professionals. All listings are self-endorsed; kinkref.org does not endorse or recommend.</p>
    </div>
  </section>

  <section class="disclaimer-section" id="disclaimer" aria-label="關於本頁列表">
    <div class="disclaimer-inner">
      <p class="disclaimer-eyebrow">⚠️ 關於本頁列表</p>
      <p>
        kinkref.org <strong>不背書、不推薦特定資源</strong>，亦不對外部資源的內容、政策、安全性負責。
        對立或競爭關係的資源<strong>全部列出</strong>，排序按字母順序或註冊日期，不按推薦度。
      </p>
      <p>
        本站對收錄條目僅進行<strong>形式審查</strong>（確認具名、專業資格證明或組織立案），
        不對專業能力、服務品質或議題熟悉度進行實質審查。
        所有條目由收錄者自我背書其專業內容。站方僅提供格式化整理與連結，
        <strong>不收任何費用</strong>（無償）。本站亦非法律服務機構，站上任何內容均不構成法律諮詢或法律意見。
      </p>
      <p>
        使用者與收錄者之間的選擇、互動及後果，由雙方自行負責。
        若產生爭議，建議回到該專業人員所屬機構或主管機關反映。
      </p>
      <p>
        收錄者可隨時來信要求<strong>修改資訊或退出名單</strong>。
        逾期未回覆定期 re-verify 達 30 天，站方將暫時下架該條目，待確認後重新上架。
        如發現外部連結失效或有資源已停止運作，亦請來信
        <a href="mailto:curator@kinkref.org">curator@kinkref.org</a> 告知。
      </p>
    </div>
  </section>

  <article class="resources-page">
    {/* §1 心理資源 */}
    <section class="resource-section" id="counselors">
      <header class="section-header">
        <p class="section-num">§1</p>
        <h2>{applyConfigs.counselors.title}</h2>
      </header>

      {allCounselors.length === 0 ? (
        <p class="section-empty">本區段目前無收錄條目。</p>
      ) : (
        <ul class="entry-list">
          {allCounselors.map((entry) => (
            <li class="entry-card">
              <article>
                <h3>{entry.data.name}</h3>
                <p class="meta">{entry.data.credentials.join('、')} · {entry.data.location}</p>
                <p>{entry.data.kink_friendly_statement.slice(0, 150)}…</p>
                {entry.data.contact_email && (
                  <p><a href={`mailto:${entry.data.contact_email}`}>{entry.data.contact_email}</a></p>
                )}
              </article>
            </li>
          ))}
        </ul>
      )}

      <aside class="community-resource" aria-label="社群資源推薦">
        <h3 class="community-resource-heading">社群資源推薦</h3>
        <div class="community-resource-card">
          <h4>
            <a
              href="https://docs.google.com/spreadsheets/d/1zyTtdvSDtiKjAVUbcNXFGKP2IQ_0DleBmZwXZxLacTk/edit?gid=1534828108"
              target="_blank"
              rel="noopener noreferrer"
            >
              臺灣 BDSMer 友善之助人工作者資源網
            </a>
          </h4>
          <p class="community-resource-desc">
            收錄 40+ 位經確認資格且本人同意公開的友善心理師名單。
            每位助人者均經整理小組確認專業資格與收錄意願。
          </p>
          <p class="community-resource-credit">
            整理：臺灣 BDSMer 友善之助人工作者資源網（長裙富翁 發起）
          </p>
          <p class="community-resource-cta">
            若您在「禁羈友善助人者名單」上，並願意公開列在 kinkref 心理資源，歡迎來信
            <a href="mailto:curator@kinkref.org?subject=[禁羈名單轉介] 您的姓名/化名">curator@kinkref.org</a>。
          </p>
          <details class="apply-details">
            <summary>📋 查看信件模板（可直接複製）</summary>
            <pre class="apply-template"><code>{T_COUNSELOR_REFERRAL}</code></pre>
            <p class="apply-note">
              來信即視為同意站方依<a href="#disclaimer">頁首聲明</a>蒐集與公開您的資料。收錄後可隨時來信修改或退出。
            </p>
          </details>
        </div>
      </aside>

      <aside class="apply-card" aria-label="開放申請收錄">
        <p class="apply-eyebrow">開放申請收錄</p>
