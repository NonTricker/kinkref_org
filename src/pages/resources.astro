      '明確同意被列在站上',
      '專長領域與 BDSM 圈相關議題（性別法、刑法、勞動法等）',
      '每 12 個月主動 re-verify',
    ],
    readme: 'https://github.com/NonTricker/kinkref_org/blob/main/content/legal/README.md',
    template: T_LEGAL,
  },
  campusGroups: {
    title: '社團資源',
    applyType: '社團官方申請',
    criteria: [
      '正式登記或穩定運作的大學社團',
      '社團官方代表（非個人社員）申請',
      '社團聚焦範圍含性別 / 性教育 / kink 議題',
      '提供社團官方聯絡管道（email 或社群帳號）',
      '每年新學期主動 re-verify',
    ],
    readme: 'https://github.com/NonTricker/kinkref_org/blob/main/content/campus-groups/README.md',
    template: T_CAMPUS,
  },
  medical: {
    title: '醫療資源',
    applyType: '醫師/診所自薦',
    criteria: [
      '具醫師執照或診所立案證明',
      '提供醫師字號或診所統編',
      '明確同意被列在站上',
      '提供 kink-friendly 服務（性健康檢查、傷口處置、情緒 / 壓力調理、心理支持等）',
