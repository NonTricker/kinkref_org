  { name: '1995 自殺防治專線', desc: '24 小時免費安心專線。', phone: '1995', hours: '24 小時' },
  { name: '1925 安心專線', desc: '衛福部 24 小時心理諮詢免費專線。', phone: '1925', hours: '24 小時' },
