---
/**
 * /guides/counselors — BDSM 友善助人者 Pillar Page
 *
 * 脈流師 WORKORDER #004（2026-05-12）：補搜尋 query「BDSM 諮商」「kink-friendly
 * 諮商師」的 entity authority page。三層 SEO 角色分工：
 *   /resources                 → 想看 kinkref 有什麼資源
 *   /guides/counselors  ← 本頁  → 從 Google 搜「BDSM 諮商」進來
 *   /resources/counselors/{x}  → 找特定助人者詳情
 *
 * Iron Law（脈流師 §7）：
 *   - Counselor listing 絕對不能 hardcode，永遠 collection-driven
 *   - 站方原則：不背書、不排序評價、不主動篩 pro_bono 置頂
 *
 * Phase 1（織法者）：本檔 skeleton（架構 + Schema + 動態 listing）
 * Phase 2（靈範師）：lead paragraph + 6 個 FAQ + selection criteria 文案 ✅ 完成 2026-05-13
 */

import { getCollection } from 'astro:content';
import PillarLayout from '@layouts/PillarLayout.astro';
import { seedShuffle, todaySeed } from '@/lib/seed-shuffle';

// ────────────────────────────────────────────────────────
// 動態抓 counselor collection
// ────────────────────────────────────────────────────────
const allCounselors = await getCollection('counselors');

// 每日 seed shuffle（避免「字母順序 = 隱性排名」展示偏誤）
const seed = todaySeed();
const shuffled = seedShuffle(allCounselors, seed);

// ────────────────────────────────────────────────────────
// 按 credentials 主類型分組（執政官 2026-05-13 指示）
// 主分組 = 助人者性質；組內維持 shuffle 順序
// 未來社工師 / 精神科醫師等職類增加時自然容納
// ────────────────────────────────────────────────────────
const CREDENTIAL_GROUPS: Array<{
  key: string;
  label: string;
  match: (creds: readonly string[]) => boolean;
}> = [
  {
    key: 'counselor',
    label: '諮商心理師',
    match: (c) => c.some((x) => x.includes('諮商心理師')),
  },
  {
    key: 'clinical',
    label: '臨床心理師',
    match: (c) => c.some((x) => x.includes('臨床心理師')),
  },
  {
    key: 'psychiatrist',
    label: '精神科醫師',
    match: (c) => c.some((x) => x.includes('精神科醫師')),
  },
  {
    key: 'social-worker',
    label: '社工師',
    match: (c) => c.some((x) => x.includes('社工師') || x.includes('社工人員')),
  },
  {
    key: 'other',
    label: '其他助人工作者',
    match: () => true, // fallback bucket
  },
];

// 每位 counselor 分配到第一個符合的群（取頭一個 match，避免重複收錄）
function getGroupKey(creds: readonly string[]): string {
  for (const g of CREDENTIAL_GROUPS) {
    if (g.match(creds)) return g.key;
  }
  return 'other';
}

const groupedCounselors = CREDENTIAL_GROUPS.map((g) => ({
  ...g,
  entries: shuffled.filter((entry) => getGroupKey(entry.data.credentials) === g.key),
})).filter((g) => g.entries.length > 0); // 空組不渲染

const totalCount = allCounselors.length;

// ────────────────────────────────────────────────────────
// SEO
// ────────────────────────────────────────────────────────
const SITE_URL = 'https://kinkref.org';
const pageURL = `${SITE_URL}/guides/counselors`;

const pageTitle = 'BDSM 友善諮商師指南｜台灣 kink-friendly 心理師名單';
const description = `台灣 ${totalCount}+ 位 BDSM 友善諮商心理師、臨床心理師、社工師、精神科醫師完整名單。經自薦同意收錄、執照可查。線上／實體諮商管道、公益方案、保密原則說明｜kinkref.org`;

// ────────────────────────────────────────────────────────
// FAQ — 6 題 Q&A，對齊真實搜尋意圖
// 入口 query 對齊：「BDSM 諮商」「kink-friendly 諮商」「BDSM 諮商 變態」
//               「諮商保密」「線上諮商 BDSM」「免費諮商 / 公益諮商」
// FAQPage Schema 從此陣列自動生成（schema 用純文字版以利 Google 解析）
// ────────────────────────────────────────────────────────
interface FAQItem {
  question: string;
  answer: string; // 內含 markdown link [text](url) 語法
}

/** 把 answer 內的 markdown link [text](url) 轉為 HTML <a> 標籤供渲染使用 */
function answerToHtml(md: string): string {
  return md.replace(
    /\[([^\]]+)\]\(([^)]+)\)/g,
    (_, text, url) => `<a href="${url}">${text}</a>`,
  );
}

/** 把 answer 內的 markdown link 移除（只保留 text），供 schema acceptedAnswer.text 使用 */
function answerToPlain(md: string): string {
  return md.replace(/\[([^\]]+)\]\(([^)]+)\)/g, (_, text) => text);
}
const faq: FAQItem[] = [
  {
    question: '怎麼找 BDSM 友善的諮商師?',
    answer:
      '建議從三條路徑:(1) 本頁名單，所有列出者都經過自薦同意收錄，並具備中華民國諮商心理師、臨床心理師、社工師或精神科醫師執照;(2) 圈內推薦，但需確認該諮商師明確表態為 kink-friendly，並非「不排斥」而是有具體訓練;(3) 直接詢問，許多諮商師會在初談討論其對 BDSM、多重關係等議題的立場。選擇時建議考慮:服務模式（線上、實體、混合）、地區、是否提供公益方案、specialty 是否對位你的議題。本站名單依「收錄與退出原則」形式審查，但不對個人專業能力背書，專業匹配仍需個人實際接觸後判斷。',
  },
  {
    question: 'BDSM 議題去諮商會被當變態嗎?',
    answer:
      '不會，前提是諮商師具備正確的學術知識。DSM-5（2013 年起）已明確區分「paraphilia（性偏好）」與「paraphilic disorder（性偏好障礙）」:合意 BDSM 實踐本身不構成精神疾病診斷，只有當興趣導致個人痛苦、功能受損或傷害他人時才符合「障礙」標準（詳見 [DSM 與性偏好分類](/glossary/dsm-paraphilia)）。本站策展立場 §6.11 合意至上與此一致。具備 BDSM 友善訓練的諮商師會將你的興趣視為自我探索議題，而非需要矯正的病徵。若初談時遇到病理化反應，這是不適配訊號，可以選擇換諮商師而非自我懷疑。',
  },
  {
    question: 'kink-friendly 諮商師跟一般諮商師有什麼不同?',
    answer:
      '差別在訓練背景與基本立場。一般諮商師可能因課程未涵蓋 BDSM 議題，仰賴主流刻板印象把 BDSM 興趣連結到創傷反應、依戀不安或自我傷害。kink-friendly 諮商師通常具備以下其一:(1) 受過 CARAS（Community-Academic Consortium for Research on Alternative Sexualities）等 BDSM 友善繼續教育;(2) 熟讀 [Wismeijer & van Assen (2013)](/bibliography/wismeijer-2013)、[Sprott & Hadcock (2018)](/bibliography/sprott-hadcock-2018) 等去病理化文獻;(3) 採用 sex-positive、kink-affirmative 取向，與 LGBT-affirmative therapy 同源。實務差別:kink-friendly 諮商師不把 BDSM 視為議題肇因，而是視為自我認同的一部分。詳見 [Lindemann (2011)](/bibliography/lindemann-2011) 對 BDSM 治療性議題的學術分析。',
  },
  {
    question: '諮商保密原則對 BDSM 議題適用嗎?',
    answer:
      '適用。中華民國《心理師法》第 17 條規定心理師對業務知悉的個案資訊負保密義務，違反者可處罰鍰並影響執業資格。BDSM 議題不在「應通報」清單內。但有三個例外需注意:(1) 未成年人，若諮商對象未滿 18 歲，部分情境（如疑似性剝削）有通報義務;(2) 明顯而立即的危險，若 BDSM 互動涉及無合意傷害他人，諮商師可能有警告或通報義務;(3) 司法調閱，法院傳喚下諮商紀錄可能被調閱。一般合意成人 BDSM 議題完全在保密範圍內，可以放心討論。對保密邊界有疑慮時，初談主動詢問是合理的。涉及法律議題詳見 [legal](/legal) 資源。',
  },
  {
    question: '線上諮商可以談 BDSM 議題嗎?',
    answer:
      '可以，但需注意平台與設置。台灣合法線上諮商必須由具諮商心理師或臨床心理師執照者執行（《心理師法》第 14 條），平台只是傳輸工具。實務考量:(1) 平台:建議選擇端對端加密的視訊平台，避免免費社群平台的訊息留存;(2) 環境:確保通話空間無他人經過，戴耳機保護對方語音不外洩;(3) 錄影與截圖:多數平台預設不錄影，但建議初談時與諮商師明確協商;(4) 付款隱私:若擔心家庭可見，可使用個人帳戶而非家庭共用帳戶。線上諮商突破了「找不到台北以外 kink-friendly 諮商師」的地理限制,本頁名單中標示「線上」服務模式者，全台可預約。',
  },
  {
    question: '沒有錢可以諮商嗎?',
    answer:
      '有三條路徑:(1) 本頁名單的公益方案，標示「✓ 公益」的諮商師提供減免費或免費名額（pro_bono 欄位），可直接聯絡諮商師詢問當前是否還有公益名額;(2) 衛福部社區心理衛生中心，各縣市政府設有社區心衛中心，提供平價或免費的初步心理諮商，但 BDSM 友善與否需個別確認;(3) 大專校院諮商中心，在學學生可使用學校的免費諮商資源。提醒:公益方案通常有名額與週數限制，不適合長期療程。若預算允許但想節省，可詢問諮商師「滑動費率」（sliding scale），部分諮商師會根據個案經濟狀況彈性調整費用。',
  },
];

// ────────────────────────────────────────────────────────
// JSON-LD: FAQPage + ItemList
// ────────────────────────────────────────────────────────
const faqSchema = faq.length > 0
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      '@id': `${pageURL}#faq`,
      mainEntity: faq.map((qa) => ({
        '@type': 'Question',
        name: qa.question,
        acceptedAnswer: { '@type': 'Answer', text: answerToPlain(qa.answer) },
      })),
    }
  : null;

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  '@id': `${pageURL}#counselors`,
  name: '台灣 BDSM 友善諮商師名單',
  numberOfItems: totalCount,
  itemListElement: shuffled.map((entry, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    url: `${SITE_URL}/resources/counselors/${entry.id}`,
    name: entry.data.name,
  })),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: '首頁', item: `${SITE_URL}/` },
    { '@type': 'ListItem', position: 2, name: '閱讀指南', item: `${SITE_URL}/guides` },
    { '@type': 'ListItem', position: 3, name: 'BDSM 友善諮商師指南', item: pageURL },
  ],
};

const jsonLd = [breadcrumbSchema, itemListSchema, ...(faqSchema ? [faqSchema] : [])];

const breadcrumbs = [
  { name: '首頁', url: '/' },
  { name: '閱讀指南', url: '/guides' },
  { name: 'BDSM 友善諮商師指南', url: '/guides/counselors' },
];

// 服務模式中文 label
const modeLabel: Record<string, string> = {
  'in-person': '實體',
  online: '線上',
  hybrid: '混合',
};
---

<PillarLayout
  title={pageTitle}
  description={description}
  eyebrow="閱讀指南 · Counselors"
  tagline="台灣 kink-friendly 心理師、臨床心理師、社工師、精神科醫師名單"
  audienceLabel="尋找助人資源"
  breadcrumbs={breadcrumbs}
  jsonLd={jsonLd}
>
  {/* Lead paragraph */}
  <section class="pillar-section pillar-lead" aria-label="導讀">
    <p>
      在台灣，BDSM 議題進入諮商室時，個案常面對兩種風險:一是諮商師把 BDSM 興趣誤判為創傷反應或人格議題;二是出於專業善意但缺乏知識，把 BDSM 視為應該「處理掉」的症狀。這兩種反應都會讓真正需要心理支持的議題(焦慮、伴侶溝通、創傷整合、身分認同)被 BDSM 標籤遮蔽，造成個案延後或放棄求助。
    </p>
    <p>
      <strong>BDSM 友善（kink-friendly）助人者</strong>不是「特殊」的諮商師，而是受過相關訓練或閱讀去病理化文獻、能將 BDSM 興趣視為個案自我認同一部分（而非病徵）的專業人員。在繁中圈，這個資源長期分散在私下圈內口耳相傳，本站試圖把這個網絡公開化。
    </p>
    <p>
      <strong>本名單的收錄原則</strong>:自薦同意為主、形式審查執照、每 12 個月 re-verify、不排序不評等。詳見頁尾<a href="#收錄與退出原則">收錄與退出原則</a>。
    </p>
    <p>
      <strong>使用建議</strong>:(1) 從「服務模式」「地區」「specialty」三個維度篩選對位的助人者;(2) 初談時主動討論其對 BDSM 議題的立場與經驗;(3) 不適配時換人不是失敗，這是健康的諮商選擇。
    </p>
  </section>

  {/* FAQ */}
  {faq.length > 0 && (
    <section class="pillar-section pillar-faq" aria-label="常見問題">
      <h2>常見問題</h2>
      <ul class="faq-list">
        {faq.map((qa, i) => (
          <li>
            <details open={i === 0}>
              <summary>
                <span class="faq-q-num">Q{i + 1}</span>
                <span class="faq-q-text">{qa.question}</span>
              </summary>
              <div class="faq-answer">
                <p set:html={answerToHtml(qa.answer)} />
              </div>
            </details>
          </li>
        ))}
      </ul>
    </section>
  )}

  {/* Counselor Listing — 按 credentials 分組 */}
  <section class="pillar-section counselors-listing" aria-label="助人者名單">
    <header class="counselors-listing-header">
      <h2>名單（{totalCount} 位）</h2>
      <p class="counselors-listing-note">
        排序為每次站台更新時隨機。本站不對個人專業能力進行排名或推薦。
      </p>
    </header>

    {groupedCounselors.map((group) => (
      <section class="counselor-group" aria-label={group.label}>
        <header class="counselor-group-header">
          <h3>
            <span class="counselor-group-label">{group.label}</span>
            <span class="counselor-group-count">{group.entries.length} 位</span>
          </h3>
        </header>
        <ul class="counselor-group-list">
          {group.entries.map((entry) => (
            <li class="counselor-row">
              <a href={`/resources/counselors/${entry.id}`}>
                <span class="counselor-row-name">{entry.data.name}</span>
                <span class="counselor-row-meta">
                  {entry.data.institution && (
                    <>
                      <span class="counselor-row-inst">{entry.data.institution}</span>
                      <span aria-hidden="true"> · </span>
                    </>
                  )}
                  <span class="counselor-row-loc">{entry.data.location}</span>
                </span>
                {entry.data.specialty && entry.data.specialty.length > 0 && (
                  <p class="counselor-row-specialty">
                    {entry.data.specialty.slice(0, 2).join('、')}
                    {entry.data.specialty.length > 2 && '⋯'}
                  </p>
                )}
                <p class="counselor-row-badges">
                  {entry.data.service_modes?.map((m) => (
                    <span class="counselor-row-mode">{modeLabel[m] ?? m}</span>
                  ))}
                  {entry.data.pro_bono?.available && (
                    <span class="counselor-row-probono">✓ 公益</span>
                  )}
                </p>
              </a>
            </li>
          ))}
        </ul>
      </section>
    ))}
  </section>

  {/* Selection Criteria */}
  <section class="pillar-section pillar-criteria" aria-label="收錄原則" id="收錄與退出原則">
    <h2>收錄與退出原則</h2>

    <h3>收錄原則（自薦同意制）</h3>
    <p>所有列出者均經過以下流程:</p>
    <ol>
      <li>
        <strong>明確 listing_consent</strong>:諮商師親自聯絡 <code>curator@kinkref.org</code> 或經圈內推薦但<strong>該諮商師明確同意</strong>收錄。
      </li>
      <li>
        <strong>執照驗證</strong>:驗證中華民國諮商心理師、臨床心理師、社工師或精神科醫師執照狀態（衛福部全國醫事系統可查）。
      </li>
      <li>
        <strong>形式審查不背書</strong>:站方僅驗證「身分真實、執照有效」，不對個人專業能力做實質背書，所有條目由收錄者自我背書其專業內容。
      </li>
      <li>
        <strong>每 12 個月 re-verify</strong>:聯絡資訊、執照狀態、服務模式定期核對。
      </li>
      <li>
        <strong>不排序、不評等</strong>:列表順序每日 seed shuffle 隨機，避免「字母順序等於隱性排名」的展示偏誤。
      </li>
      <li>
        <strong>不主動篩 pro_bono 置頂</strong>:公益方案的諮商師有標記但不置頂，遵守「不背書」原則。
      </li>
    </ol>

    <h3>退出機制</h3>
    <p>收錄者可隨時要求下架，無需理由:</p>
    <ul>
      <li>寄信至 <code>curator@kinkref.org</code> 即可</li>
      <li>24 小時內完成下架</li>
      <li>過去個別頁面 URL 會以 410 Gone 回應，避免 Google 持續索引死頁</li>
    </ul>

    <h3>為什麼這樣設計?</h3>
    <p>
      站方在「資源能見度」與「不誤導讀者」之間求平衡。承諾過度（背書專業能力）會把資源轉化為偽推薦系統，但完全去中心化（不形式審查）會降低名單可信度。本設計的策略是:<strong>站方負責「身分真實 + 同意收錄」的形式保證，讀者承擔「專業匹配 + 實際接觸」的判斷責任</strong>。
    </p>
    <p>
      完整投稿管道與 schema 規範詳見 <a href="https://github.com/zaious-design/kinkref-org/blob/main/content/counselors/README.md">GitHub repo 的 counselors README</a>。
      <a href="/resources#disclaimer">完整站方聲明 →</a>
    </p>
  </section>

  {/* Cross-link to related pages */}
  <section class="pillar-section pillar-related" aria-label="相關頁面">
    <h2>相關資源</h2>
    <ul class="related-guides">
      <li>
        <a href="/resources">
          <span class="related-guide-title">外部資源總覽</span>
          <span class="related-guide-tagline">心理、法律、社團、醫療整合資源頁</span>
        </a>
      </li>
      <li>
        <a href="/guides/practitioners">
          <span class="related-guide-title">圈內實踐者進階</span>
          <span class="related-guide-tagline">D/s 關係、Scene 設計、心理動態與善後</span>
