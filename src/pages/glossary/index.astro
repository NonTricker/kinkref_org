---
/**
 * Glossary index — 術語表列表頁
 *
 * 顯示：依字母排序的所有術語條目，含中英對照、tagline、tag 摘要。
 * Filter（占位 — 後續 client-side filter）：
 *   - by topic_tag
 *   - by reader_tag
 */

import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import SearchBox from '@components/SearchBox.astro';
import TagPill from '@components/TagPill.astro';
import { renderInlineMarkdown, stripInlineMarkdown } from '@/lib/inline-markdown';

const allTerms = await getCollection('glossary');

// 6 個核心定義詞置頂（執政官 v0.5.6 指示）：BDSM / DS / SM / BD / SSC / RACK
// 順序對應主人原話：「BDSM DS SM BD SSC RACK」
const PINNED_SLUGS = [
  'bdsm',
  'dominance-submission',
  'sadism-masochism',
  'bondage-discipline',
  'ssc',
  'rack',
];

const pinnedSet = new Set(PINNED_SLUGS);

// 找出 pinned 條目（按 PINNED_SLUGS 順序保留）
const pinnedTerms = PINNED_SLUGS
  .map((slug) => allTerms.find((t) => t.id === slug))
  .filter((t): t is NonNullable<typeof t> => t !== undefined);

// 其餘條目依英文 term 字母排序
const restTerms = allTerms
  .filter((t) => !pinnedSet.has(t.id))
  .sort((a, b) =>
    a.data.term_en.toLowerCase().localeCompare(b.data.term_en.toLowerCase())
  );

const sortedTerms = [...pinnedTerms, ...restTerms];

// 取所有 topic_tags（去重）供 filter UI 用
const allTopicTags = [...new Set(allTerms.flatMap((entry) => entry.data.topic_tags))].sort();

const pageTitle = '術語表 · Glossary';
const pageDescription = `BDSM 學術術語的中英對照與辨析，**策展持續擴充**。剛測完 bdsmtest 想搜 archetype？想理解 sub vs M、pet vs slave 等圈內微分？每個條目附對偶辨析、爭議標註、DSM 區別、圈內用法說明，並標明翻譯哲學選擇（如「奴僕」為何不譯為「奴隸」）。`;
const metaDescription = stripInlineMarkdown(pageDescription);
---

<BaseLayout title={pageTitle} description={metaDescription}>
  <section class="page-hero">
    <div class="page-hero-inner">
      <p class="page-eyebrow">
        <span class="page-eyebrow-num">01</span>
        <span class="page-eyebrow-sep" aria-hidden="true">·</span>
        <span class="page-eyebrow-name">Glossary</span>
      </p>
      <h1 class="page-title">術語表</h1>
      <hr class="page-title-rule" aria-hidden="true" />
      <p class="page-description" set:html={renderInlineMarkdown(pageDescription)} />
      <div class="page-search">
        <SearchBox placeholder="搜尋術語…" variant="hero" />
      </div>
    </div>
  </section>

  <section class="page-toolbar" aria-label="篩選">
    <div class="page-toolbar-inner">
      <p class="toolbar-label">主題篩選：</p>
      <ul class="toolbar-tags">
        {
          allTopicTags.map((tag) => (
            <li>
              <TagPill label={tag} variant="topic" size="sm" href={`/glossary?topic=${tag}`} />
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="entry-list-section">
    <ul class="entry-list">
      {
        sortedTerms.map((entry, i) => (
          <li class="entry-card">
            <a href={`/glossary/${entry.id}`}>
              {pinnedSet.has(entry.id) && (
                <span class="entry-card-pin" aria-label="置頂條目" title="核心定義詞">◆</span>
              )}
              <span class="entry-card-no" aria-hidden="true">№{(i + 1).toString().padStart(3, '0')}</span>
              <header class="entry-card-header">
                <h2 class="entry-card-title">
                  <span class="entry-card-en">{entry.data.term_en}</span>
                  <span class="entry-card-zh">{entry.data.term_zh}</span>
                </h2>
                {entry.data.aliases_en && (
                  <p class="entry-card-aliases">
                    <span class="entry-card-meta-label">aka.</span>
                    {entry.data.aliases_en}
                  </p>
                )}
              </header>
              <p class="entry-card-tagline">{entry.data.tagline}</p>
              <ul class="entry-card-tags">
                {entry.data.topic_tags.slice(0, 3).map((tag) => (
                  <li>
                    <TagPill label={tag} variant="topic" size="sm" />
                  </li>
                ))}
              </ul>
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>

<style>
  .page-hero {
    padding: var(--space-11) var(--space-5) var(--space-9);
    border-bottom: 1px solid var(--rule-fine);
  }

  .page-hero-inner {
    max-width: var(--content-width-index);
    margin: 0 auto;
  }

  /* ──────────────────────────────────────────────────────
     Page Hero — V2 Polish: 編號 + 章節點 + baseline rule
     對標：Aeon / The Atlantic / Stanford SEP 的編輯感
     ────────────────────────────────────────────────────── */
  .page-eyebrow {
    font-family: var(--font-sans);
    font-size: var(--fs-eyebrow);
    text-transform: uppercase;
    letter-spacing: var(--ls-eyebrow);
    color: var(--accent-primary);
    margin: 0 0 var(--space-4);
    display: inline-flex;
    align-items: baseline;
    gap: 8px;
  }

  .page-eyebrow-num {
    font-family: var(--font-mono);
    font-weight: var(--fw-semibold);
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.04em;
  }

  .page-eyebrow-sep {
    color: var(--ink-disabled);
    font-weight: var(--fw-regular);
  }

  .page-eyebrow-name {
    font-weight: var(--fw-semibold);
  }

  .page-title {
    font-size: var(--fs-h1);
    font-weight: var(--fw-semibold);
    letter-spacing: var(--ls-h1);
    line-height: var(--lh-tight);
    margin: 0 0 var(--space-5);
  }

  /* Baseline rule — h1 與 description 間的編輯裝飾線 */
  .page-title-rule {
    width: 64px;
    height: 1px;
    background: var(--accent-primary);
    border: 0;
    margin: 0 0 var(--space-6);
  }

  /* Hero description 對齊 page-hero-inner（1024px），與 search box / toolbar 視覺一致。
     65ch 紀律僅保留給「詳情頁長文段落」（EntryLayout :global 規則）。 */
  .page-description {
    font-size: var(--fs-body);
    line-height: var(--lh-body);
    color: var(--ink-meta);
    margin: 0 0 var(--space-7);
  }

  .page-description :global(strong) {
    color: var(--ink-heading);
    font-weight: var(--fw-semibold);
  }

  /* SearchBox 拉滿主內容區寬度，跟下方卡片對齊 */
  .page-search {
    max-width: 100%;
  }

  .page-toolbar {
    padding: var(--space-5) var(--space-5);
    background: var(--bg-subtle);
    border-bottom: 1px solid var(--rule-fine);
  }

  .page-toolbar-inner {
    max-width: var(--content-width-index);
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .toolbar-label {
    font-family: var(--font-sans);
    font-size: var(--fs-caption);
    color: var(--ink-meta);
    margin: 0;
  }

  .toolbar-tags {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .entry-list-section {
    padding: var(--space-9) var(--space-5) var(--space-11);
  }

  .entry-list {
    max-width: var(--content-width-index);
    margin: 0 auto;
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: var(--space-5);
  }

  /* ──────────────────────────────────────────────────────
     Card — V2 Polish: D（純 typographic 分量）+ 微 A（右上角編號）
     - 移除 translateX hover（過於 SaaS）
     - 改用 ::before 左側書脊 grow（0 → 3px）
     - title hover underline grow
     - 右上角極小 paper-trail 編號（Are.na/Aeon 編輯感）
     ────────────────────────────────────────────────────── */
  .entry-card a {
    position: relative;
    display: block;
    padding: var(--space-5) var(--space-7);
    background: var(--bg-elevated);
    border: 1px solid var(--rule-fine);
    border-radius: var(--radius-sm);
    text-decoration: none;
    color: var(--ink-body);
    height: 100%;
    overflow: hidden; /* 讓 ::before 不溢出 */
    transition: border-color 150ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .entry-card a::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    bottom: 0;
    width: 0;
    background: var(--accent-primary);
    transition: width 200ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .entry-card a:hover {
    border-color: var(--accent-primary);
  }

  .entry-card a:hover::before {
    width: 3px;
  }

  .entry-card a:focus-visible {
    outline: 2px solid var(--accent-primary);
    outline-offset: 2px;
  }

  /* 右上角 paper-trail 編號 */
  .entry-card-no {
    position: absolute;
    top: var(--space-4);
    right: var(--space-5);
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: var(--fw-medium);
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.06em;
    color: var(--ink-disabled);
    line-height: 1;
  }

  /* 左上角 pin 標記（v0.5.11）— 6 個核心定義詞置頂注記
     與右上角 №001 對位 mirror，純紅小符號，不破壞 paper-trail 紀律 */
  .entry-card-pin {
    position: absolute;
    top: var(--space-4);
    left: var(--space-5);
    font-size: 9px;
    color: var(--accent-primary);
    line-height: 1;
    letter-spacing: 0;
    /* 提升一點 z 確保不被書脊 ::before 蓋住 */
    z-index: 1;
  }

  .entry-card-header {
    margin-bottom: var(--space-3);
    /* 留空間給編號 */
    padding-right: var(--space-7);
  }

  .entry-card-title {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  /* Title underline grow on hover — 微互動（::after pseudo，不踩 gradient 鐵律） */
  .entry-card-en {
    position: relative;
    display: inline-block;
    font-size: var(--fs-h3);
    font-family: var(--font-serif);
    font-weight: var(--fw-semibold);
    color: var(--ink-heading);
    letter-spacing: var(--ls-tight);
    padding-bottom: 2px;
  }

  .entry-card-en::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 0;
    height: 1px;
    width: 0;
    background: var(--accent-primary);
    transition: width 200ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .entry-card a:hover .entry-card-en::after {
    width: 100%;
  }

  .entry-card-zh {
    font-family: var(--font-sans);
    font-size: var(--fs-body-sm);
    color: var(--ink-meta);
    font-weight: var(--fw-regular);
    letter-spacing: 0.02em;
  }

  .entry-card-aliases {
    margin: var(--space-3) 0 0;
    font-family: var(--font-sans);
    font-size: var(--fs-caption);
    color: var(--ink-meta);
  }

  .entry-card-meta-label {
    color: var(--ink-disabled);
    margin-right: var(--space-2);
    font-style: italic;
    font-variant: small-caps;
  }

  .entry-card-tagline {
    font-size: var(--fs-body-sm);
    line-height: var(--lh-body);
    color: var(--ink-body);
    margin: 0 0 var(--space-4);
  }

  .entry-card-tags {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  @media (prefers-reduced-motion: reduce) {
    .entry-card a,
    .entry-card a::before,
    .entry-card-en::after {
      transition: none;
    }
  }
</style>
