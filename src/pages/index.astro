---
/**
 * Homepage — kinkref.org
 *
 * 結構（依 DESIGN_PRINCIPLES.md）：
 *  - Hero（站名 + 一句話定位 + 搜尋）
 *  - 內容四柱卡片（Glossary / Bibliography / Books / Journals）
 *  - 最近更新區
 *  - 站方立場聲明
 *
 * v0.4.7：四柱 count 全部連動 getCollection().length
 */

import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import SearchBox from '@components/SearchBox.astro';

// 並行讀四個 collection（Astro Content Layer 已內快取）
const [allGlossary, allBibliography, allBooks, allJournals] = await Promise.all([
  getCollection('glossary'),
  getCollection('bibliography'),
  getCollection('books'),
  getCollection('journals'),
]);

// 取最近更新的 6 筆 glossary 條目
const recentTerms = allGlossary
  .sort((a, b) => b.data.last_reviewed.getTime() - a.data.last_reviewed.getTime())
  .slice(0, 6);

// v0.8.2：FAQPage Schema 已搬到 /qa 頁面（schema.org 預期 FAQ schema 對應 FAQ page，
// 不在首頁）。首頁回到純 WebSite + Organization schema（由 BaseLayout 提供）。

const pillars = [
  {
    href: '/glossary',
    eyebrow: 'Glossary',
    title: '術語表',
    description: '中英對照的學術定義索引。每個術語標註首見年代、辨析與相關詞。',
    count: allGlossary.length,
    countLabel: '條',
  },
  {
    href: '/bibliography',
    eyebrow: 'Bibliography',
    title: '學術文獻',
    description: '按主題分類的論文摘要。標示 OA 狀態、研究方法與翻譯進度。',
    count: allBibliography.length,
    countLabel: '篇',
  },
  {
    href: '/books',
    eyebrow: 'Books',
    title: '書架清單',
    description: '已驗證的書目。每本書附中文書摘、推薦章節與取得方式。',
    count: allBooks.length,
    countLabel: '本',
  },
  {
    href: '/journals',
    eyebrow: 'Journals',
    title: '投稿地圖',
    description: '性學 / 心理學期刊指南。IF、OA 狀態、submission policy、acceptance rate。',
    count: allJournals.length,
    countLabel: '本',
  },
];
---

<BaseLayout title="Kink Reference">
  <section class="hero">
    <div class="hero-inner">
      <p class="hero-eyebrow">Kink Reference · 中文 BDSM 學術策展</p>
      <h1 class="hero-title">學術轉譯，而非介紹媒合。</h1>
      <p class="hero-tagline">
        台灣中文圈專注 BDSM 學術文獻策展、術語索引與期刊投稿地圖。
        中英對照、註明來源、結構化貢獻、開源授權。
      </p>
      <div class="hero-search">
        <SearchBox variant="hero" placeholder="搜尋術語、論文、書目、期刊（試試「safe word」）" />
      </div>
    </div>
  </section>

  <section class="pillars" aria-labelledby="pillars-heading">
    <div class="pillars-inner">
      <h2 id="pillars-heading" class="section-heading">內容四柱</h2>
      <div class="pillars-grid">
        {
          pillars.map((p) => (
            <a class="pillar-card" href={p.href}>
              <p class="pillar-eyebrow">{p.eyebrow}</p>
              <h3 class="pillar-title">{p.title}</h3>
              <p class="pillar-description">{p.description}</p>
              <p class="pillar-count">
                <span class="pillar-count-num">{p.count}</span>
                <span class="pillar-count-unit">{p.countLabel}</span>
              </p>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section class="recent" aria-labelledby="recent-heading">
    <div class="recent-inner">
      <h2 id="recent-heading" class="section-heading">最近更新的術語</h2>
      <ul class="recent-list">
        {
          recentTerms.map((entry) => (
            <li class="recent-item">
              <a href={`/glossary/${entry.id}`}>
                <span class="recent-term-zh">{entry.data.term_zh}</span>
                <span class="recent-term-en">{entry.data.term_en}</span>
              </a>
              <p class="recent-tagline">{entry.data.tagline}</p>
            </li>
          ))
        }
      </ul>
      <p class="recent-cta">
        <a href="/glossary">查看完整術語表 →</a>
      </p>
    </div>
  </section>

  <section class="readers" aria-labelledby="readers-heading">
    <div class="readers-inner">
      <h2 id="readers-heading" class="section-heading">讀者來自</h2>
      <p class="readers-flags" id="readers-flags"></p>
      <p class="readers-source" id="readers-source"></p>
    </div>
  </section>

  <script is:inline>
    /* 首頁國家 flags — 從 /api/stats.json 讀取（build-time 生成）
       讀 lifetime 區段（自啟站累計），不是 top-level 的近 7 天。
       Fallback：lifetime 不在 → 舊 schema → 用 top-level countries。 */
    (function () {
      const FLAGS = {
        TW: '🇹🇼', HK: '🇭🇰', US: '🇺🇸', JP: '🇯🇵', SG: '🇸🇬',
        CN: '🇨🇳', MY: '🇲🇾', CA: '🇨🇦', KR: '🇰🇷', GB: '🇬🇧',
        DE: '🇩🇪', FR: '🇫🇷', AU: '🇦🇺', VN: '🇻🇳',
      };
      const NAMES = {
        TW: 'Taiwan', HK: 'Hong Kong', US: 'US', JP: 'Japan', SG: 'Singapore',
        CN: 'China', MY: 'Malaysia', CA: 'Canada', KR: 'Korea', GB: 'UK',
      };
      fetch('/api/stats.json')
        .then(function (r) { return r.json(); })
        .then(function (d) {
          var pool = (d.lifetime && d.lifetime.countries) || d.countries;
          var rangeStart = (d.lifetime && d.lifetime.period && d.lifetime.period.start) || '';
          var rangeEnd = (d.lifetime && d.lifetime.period && d.lifetime.period.end) ||
                         (d.generated || '').slice(0, 10);
          if (!pool || !pool.length) return;
          var el = document.getElementById('readers-flags');
          var src = document.getElementById('readers-source');
          if (!el) return;
          el.innerHTML = pool
            .slice(0, 5)
            .map(function (c) {
              return (FLAGS[c.code] || '') + ' ' + (NAMES[c.code] || c.code) +
                ' <span class="readers-count">' + c.views.toLocaleString() + '</span>';
            })
            .join('  <span class="readers-sep">\u00b7</span>  ');
          if (src) {
            var label = rangeStart
              ? '\u81ea ' + rangeStart + ' \u555f\u7ad9\u7d2f\u8a08'  // 自 YYYY-MM-DD 啟站累計
              : '\u7d2f\u8a08';
            src.innerHTML = label +
              ' \u00b7 <a href="/dashboard">\u67e5\u770b\u5b8c\u6574\u6578\u64da \u2192</a>';
          }
        })
        .catch(function () { /* no-op */ });
    })();
  </script>

  <section class="position" aria-labelledby="position-heading">
    <div class="position-inner">
      <h2 id="position-heading" class="section-heading">這個站是什麼，不是什麼</h2>
      <div class="position-grid">
        <div class="position-card position-card--is">
          <h3>是</h3>
          <ul>
            <li>英文學術文獻的中文摘要</li>
            <li>術語的中英對照與辨析</li>
            <li>方法論透明的策展</li>
            <li>CC BY-SA 授權的開放資源</li>
          </ul>
        </div>
        <div class="position-card position-card--isnt">
          <h3>不是</h3>
          <ul>
            <li>社群論壇</li>
            <li>安全操作指引站</li>
            <li>個人或工作室推薦平台</li>
            <li>情色站</li>
          </ul>
        </div>
      </div>
      <p class="position-cta">
        <a href="/about">完整站方立場 →</a>
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    /* v0.5.7：留白稍壓縮（執政官指示「有點空」） */
    padding: var(--space-10) var(--space-5) var(--space-9);
    border-bottom: 1px solid var(--rule-fine);
  }

  .hero-inner {
    max-width: var(--content-width-prose);
    margin: 0 auto;
  }

  .hero-eyebrow {
    font-family: var(--font-sans);
    font-size: var(--fs-eyebrow);
    text-transform: uppercase;
    letter-spacing: var(--ls-eyebrow);
    color: var(--accent-primary);
    margin: 0 0 var(--space-5);
  }

  .hero-title {
    font-size: var(--fs-display);
    line-height: var(--lh-tight);
    letter-spacing: var(--ls-display);
    margin: 0 0 var(--space-5);
  }

  .hero-tagline {
    /* v0.5.7：字升一階至 19px（首頁 scope，不影響其他頁面 var(--fs-body) 17px 紀律） */
    font-size: 1.1875rem;
    line-height: var(--lh-body);
    color: var(--ink-meta);
    max-width: 52ch;
    margin: 0 0 var(--space-8);
  }

  .hero-search {
    max-width: 600px;
  }

  .pillars,
  .recent,
  .position {
    /* v0.5.7：section padding 壓縮一階 */
    padding: var(--space-10) var(--space-5);
    border-bottom: 1px solid var(--rule-fine);
  }

  .pillars-inner,
  .recent-inner,
  .position-inner {
    max-width: var(--content-width-index);
    margin: 0 auto;
  }

  .section-heading {
    font-size: var(--fs-h2);
    /* v0.5.7：標題與內容間距壓緊 */
    margin: 0 0 var(--space-7);
  }

  /* 內容四柱：永遠單行，太窄則橫向 scroll（不 wrap）
     執政官 v0.4.9：寧可滾輪也不要兩行的視覺斷裂感 */
  .pillars-grid {
    display: flex;
    gap: var(--space-5);
    overflow-x: auto;
    padding-bottom: var(--space-3); /* 預留 scrollbar 視覺空間 */
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
  }

  /* flex-grow 1 讓寬螢幕均分；flex-basis 220px 最小寬；不縮（shrink 0）強制單行 */
  .pillar-card {
    flex: 1 0 220px;
    scroll-snap-align: start;
  }

  .pillar-card {
    display: block;
    padding: var(--space-7);
    background: var(--bg-elevated);
    border: 1px solid var(--rule-fine);
    border-radius: var(--radius-sm);
    text-decoration: none;
    color: var(--ink-body);
    transition:
      var(--transition-color),
      transform var(--transition-fast);
  }

  .pillar-card:hover {
    border-color: var(--accent-primary);
    transform: translateY(-2px);
  }

  .pillar-eyebrow {
    font-family: var(--font-sans);
    font-size: var(--fs-eyebrow);
    text-transform: uppercase;
    letter-spacing: var(--ls-eyebrow);
    color: var(--accent-primary);
    margin: 0 0 var(--space-3);
  }

  .pillar-title {
    font-size: var(--fs-h3);
    margin: 0 0 var(--space-4);
  }

  .pillar-description {
    font-size: var(--fs-body-sm);
    line-height: var(--lh-body);
    color: var(--ink-meta);
    margin: 0 0 var(--space-5);
  }

  .pillar-count {
    margin: 0;
    display: flex;
    align-items: baseline;
    gap: var(--space-2);
    font-family: var(--font-sans);
  }

  .pillar-count-num {
    font-family: var(--font-serif);
    font-size: var(--fs-h2);
    font-weight: var(--fw-bold);
    color: var(--accent-primary);
    font-variant-numeric: tabular-nums;
  }

  .pillar-count-unit {
    font-size: var(--fs-caption);
    color: var(--ink-meta);
  }

  .recent-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-7);
  }

  .recent-item a {
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
    text-decoration: none;
    color: var(--ink-heading);
    margin-bottom: var(--space-2);
  }

  .recent-item a:hover .recent-term-zh {
    color: var(--accent-primary);
  }

  .recent-term-zh {
    font-size: var(--fs-h4);
    font-weight: var(--fw-semibold);
    transition: var(--transition-color);
  }

  .recent-term-en {
    font-family: var(--font-sans);
    font-size: var(--fs-caption);
    color: var(--ink-meta);
    font-style: italic;
  }

  .recent-tagline {
    font-size: var(--fs-body-sm);
    line-height: var(--lh-body);
    color: var(--ink-meta);
    margin: 0;
  }

  .recent-cta,
  .position-cta {
    /* v0.5.7：CTA 距離壓緊 */
    margin-top: var(--space-7);
  }

  .recent-cta a,
  .position-cta a {
    color: var(--accent-primary);
    text-decoration: none;
    font-family: var(--font-sans);
    font-weight: var(--fw-medium);
  }

  .recent-cta a:hover,
  .position-cta a:hover {
    text-decoration: underline;
  }

  .position-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-7);
  }

  .position-card {
    padding: var(--space-7);
    border: 1px solid var(--rule-fine);
    border-radius: var(--radius-sm);
  }

  .position-card h3 {
    font-family: var(--font-sans);
    font-size: var(--fs-h4);
    margin: 0 0 var(--space-4);
    text-transform: uppercase;
    letter-spacing: var(--ls-eyebrow);
  }

  .position-card--is h3 {
    color: var(--status-oa);
  }

  .position-card--isnt h3 {
    color: var(--accent-primary);
  }

  .position-card ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .position-card li {
    font-size: var(--fs-body-sm);
    line-height: var(--lh-body);
  }

  /* ── Readers / 國家 flags ── */
  .readers {
    padding: var(--space-9) var(--space-5);
    border-bottom: 1px solid var(--rule-fine);
    text-align: center;
  }

  .readers-inner {
    max-width: var(--content-width-index);
    margin: 0 auto;
  }

  .readers-flags {
    font-size: var(--fs-h4);
    color: var(--ink-body);
    margin: 0 0 var(--space-3);
    letter-spacing: 0.02em;
    line-height: 2;
  }

  .readers-source {
    font-family: var(--font-sans);
    font-size: var(--fs-caption);
    color: var(--ink-disabled);
    margin: 0;
  }

  .readers-source :global(a) {
    color: var(--accent-primary);
    text-decoration: none;
    font-weight: var(--fw-medium);
  }

  .readers-source :global(a:hover) {
    text-decoration: underline;
  }

  :global(.readers-count) {
    font-family: var(--font-mono);
    font-size: var(--fs-caption);
    color: var(--ink-meta);
    font-variant-numeric: tabular-nums;
  }

  :global(.readers-sep) {
    color: var(--ink-disabled);
  }

  @media (max-width: 640px) {
    .position-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ──────────────────────────────────────────────────────
     v0.6.2：手機版四柱改 2x2 grid，避免橫向 scroll
     桌面維持 flex 單行 + horizontal scroll if needed（執政官 v0.4.9 指示）
     ────────────────────────────────────────────────────── */
  @media (max-width: 720px) {
    .pillars-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--space-3);
      overflow-x: visible;
      padding-bottom: 0;
      scroll-snap-type: none;
    }

    .pillar-card {
      flex: none; /* override flex 1 0 220px */
      scroll-snap-align: none;
      padding: var(--space-5);
    }

    /* 手機版 description 在 2x2 緊湊 layout 下太擠，隱藏 */
    .pillar-description {
      display: none;
    }

    /* 手機版 pillar-count 改為單行緊湊：數字 + 單位 inline */
    .pillar-count-num {
      font-size: var(--fs-h3);
    }
  }
</style>
