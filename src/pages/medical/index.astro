---
/**
 * Medical directory — Kink-friendly 醫療資源 + 公開緊急熱線
 * v0.4.0 新建（schema v1.3）
 */

import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';

const allMedical = await getCollection('medical');
const sorted = allMedical.sort((a, b) => {
  // hotline / support-org 排前面（公開資源優先）
  const order = { hotline: 0, 'support-org': 1, clinic: 2, physician: 3 };
  return (order[a.data.entry_type] ?? 9) - (order[b.data.entry_type] ?? 9);
});

const pageTitle = '醫療資源 · Medical';
const pageDescription =
  'Kink-friendly 醫師、診所、性健康服務 directory；含台灣公開緊急熱線（113 / 1995 / 1925）。醫師/診所須自薦同意收錄，公開政府專線可直接列入。';
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <section class="page-hero">
    <div class="page-hero-inner">
      <p class="page-eyebrow">
        <span class="page-eyebrow-num">09</span>
        <span class="page-eyebrow-sep" aria-hidden="true">·</span>
        <span class="page-eyebrow-name">Medical</span>
      </p>
      <h1 class="page-title">醫療資源</h1>
      <hr class="page-title-rule" aria-hidden="true" />
      <p class="page-description">{pageDescription}</p>
    </div>
  </section>

  {
    sorted.length === 0 ? (
      <section class="empty-state">
        <div class="empty-state-inner">
          <p class="empty-state-eyebrow">尚未開放</p>
          <h2>醫療資源 directory 待填</h2>
          <p>
            本目錄收錄 kink-friendly 醫師、診所、性健康服務，並列出台灣公開可訪問的緊急熱線。
          </p>
          <p>
            醫師/診所須自薦並同意收錄；
            公開緊急熱線（113 婦幼保護專線、1995 自殺防治、1925 安心專線）將陸續列入。
            自薦請來信 <a href="mailto:curator@kinkref.org">curator@kinkref.org</a>。
          </p>
          <p>
            詳細收錄原則見
            <a
              href="https://github.com/NonTricker/kinkref_org/blob/main/content/medical/README.md"
              target="_blank"
              rel="noopener noreferrer"
            >
              content/medical/README.md
            </a>
            。
          </p>
        </div>
      </section>
    ) : (
      <section class="entry-list-section">
        <ul class="entry-list">
          {sorted.map((entry) => (
            <li class="entry-card">
              <article>
                <p class="entry-type">{entry.data.entry_type}</p>
                <h2>{entry.data.name}</h2>
                {entry.data.contact_phone && (
                  <p class="phone">
                    <a href={`tel:${entry.data.contact_phone}`}>{entry.data.contact_phone}</a>
                  </p>
                )}
                {entry.data.available_hours && <p class="hours">{entry.data.available_hours}</p>}
                <p class="description">{entry.data.description.slice(0, 120)}…</p>
              </article>
            </li>
          ))}
        </ul>
      </section>
    )
  }
</BaseLayout>

<style>
  .page-hero { padding: var(--space-11) var(--space-5) var(--space-9); border-bottom: 1px solid var(--rule-fine); }
  .page-hero-inner { max-width: var(--content-width-index); margin: 0 auto; }
  .page-eyebrow { font-family: var(--font-sans); font-size: var(--fs-eyebrow); text-transform: uppercase; letter-spacing: var(--ls-eyebrow); color: var(--accent-primary); margin: 0 0 var(--space-4); display: inline-flex; align-items: baseline; gap: 8px; }
  .page-eyebrow-num { font-family: var(--font-mono); font-weight: var(--fw-semibold); font-variant-numeric: tabular-nums; letter-spacing: 0.04em; }
  .page-eyebrow-sep { color: var(--ink-disabled); }
  .page-eyebrow-name { font-weight: var(--fw-semibold); }
  .page-title { font-size: var(--fs-h1); font-weight: var(--fw-semibold); line-height: var(--lh-tight); margin: 0 0 var(--space-5); }
  .page-title-rule { width: 64px; height: 1px; background: var(--accent-primary); border: 0; margin: 0 0 var(--space-6); }
  .page-description { font-size: var(--fs-body); line-height: var(--lh-body); color: var(--ink-meta); margin: 0; }
  .empty-state { padding: var(--space-12) var(--space-5); }
  .empty-state-inner { max-width: var(--content-width-prose); margin: 0 auto; text-align: center; }
  .empty-state-eyebrow { font-family: var(--font-sans); font-size: var(--fs-eyebrow); text-transform: uppercase; letter-spacing: var(--ls-eyebrow); color: var(--ink-disabled); margin: 0 0 var(--space-4); }
  .empty-state h2 { font-size: var(--fs-h2); margin: 0 0 var(--space-5); }
  .empty-state p { color: var(--ink-meta); line-height: var(--lh-body); margin: 0 0 var(--space-4); }
  .empty-state a { color: var(--accent-primary); }

  .entry-list-section { padding: var(--space-9) var(--space-5) var(--space-11); }
  .entry-list { max-width: var(--content-width-index); margin: 0 auto; list-style: none; padding: 0; display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: var(--space-5); }
  .entry-card article { padding: var(--space-5) var(--space-6); background: var(--bg-elevated); border: 1px solid var(--rule-fine); border-left: 3px solid var(--accent-primary); border-radius: var(--radius-sm); }
  .entry-type { font-family: var(--font-sans); font-size: var(--fs-eyebrow); text-transform: uppercase; letter-spacing: var(--ls-eyebrow); color: var(--accent-primary); margin: 0 0 var(--space-2); }
  .entry-card h2 { font-size: var(--fs-h3); margin: 0 0 var(--space-2); }
  .phone { font-family: var(--font-mono); font-size: var(--fs-h3); margin: 0 0 var(--space-2); }
  .phone a { color: var(--accent-primary); text-decoration: none; }
  .hours { font-family: var(--font-sans); font-size: var(--fs-caption); color: var(--ink-meta); margin: 0 0 var(--space-2); }
  .description { font-size: var(--fs-body-sm); line-height: var(--lh-body); color: var(--ink-body); margin: var(--space-3) 0 0; }
</style>
