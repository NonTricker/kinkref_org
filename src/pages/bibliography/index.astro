---
/**
 * Bibliography index — 文獻指南列表頁
 *
 * v0.3.0 加入篩選器：topic_tags / access_type / study_type / difficulty
 * （client-side filter via URL search params + native CSS [data-*] selectors）
 *
 * Filter UI：toolbar row（active 狀態反白）
 * Empty state：保留靈範師 R 的三角色語言
 */

import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import SearchBox from '@components/SearchBox.astro';
import TagPill from '@components/TagPill.astro';
import { renderInlineMarkdown, stripInlineMarkdown } from '@/lib/inline-markdown';

const allPapers = await getCollection('bibliography');

// v0.8.0：建立「有翻譯」slug Set，用於卡片角落 marker
const allTranslations = await getCollection('translations');
const translatedSlugs = new Set(
  allTranslations.map((t) => t.id.replace(/-zh$/, ''))
);

const sortedPapers = allPapers.sort((a, b) => b.data.year - a.data.year);

// 收集篩選器來源（去重 + 排序）
const allTopicTags = [...new Set(allPapers.flatMap((p) => p.data.topic_tags))].sort();
const allStudyTypes = [...new Set(allPapers.map((p) => p.data.study_type))].sort();
const allAccessTypes = [...new Set(allPapers.map((p) => p.data.access_type))].sort();

const pageTitle = '學術文獻 · Bibliography';
// pageDescription 含 inline markdown，visible 端 render 成 HTML；
// metaDescription 為去除 markup 後的純文字，給 <meta> / OG / Twitter card 用。
const pageDescription = `BDSM 學術論文的中文摘要與索引，**策展持續擴充**。聚焦三條主軸：**去病理化**（Wismeijer 2013、Connolly 2006、Moser-Kleinplatz 2006）、**同意框架歷史**（Williams 4Cs、Pitagora 同意 vs 脅迫）、**BDSM 神經科學**（Sagarin 2009、Klement 2017）。所有條目附 DOI 或 article URL、OA 狀態、研究類型、樣本資訊與站方策展導讀。中文摘要為**策展視角重寫**，非機翻原文——讓讀者直接看到「這篇論文對你有什麼用」。`;
const metaDescription = stripInlineMarkdown(pageDescription);
---

<BaseLayout title={pageTitle} description={metaDescription}>
  <section class="page-hero">
    <div class="page-hero-inner">
      <p class="page-eyebrow">
        <span class="page-eyebrow-num">02</span>
        <span class="page-eyebrow-sep" aria-hidden="true">·</span>
        <span class="page-eyebrow-name">Bibliography</span>
      </p>
      <h1 class="page-title">學術文獻</h1>
      <hr class="page-title-rule" aria-hidden="true" />
      <p class="page-description" set:html={renderInlineMarkdown(pageDescription)} />
      <p class="page-description-en" lang="en">Curated paper abstracts with Chinese summaries, DOI links, and curation-depth indicators. Organized by topic — depathologization, consent culture, neuroscience, cross-cultural studies.</p>
      <div class="page-search">
        <SearchBox placeholder="搜尋論文標題、作者…" variant="hero" />
      </div>
    </div>
  </section>

  {
    sortedPapers.length === 0 ? (
      <section class="empty-state">
        <div class="empty-state-inner">
          <p class="empty-state-eyebrow">尚未開放</p>
          <h2>學術文獻正在編纂中</h2>
          <p>
            首批論文摘要正由 AI 心理學家 Agent 繆思生成、策展人薩約審校中。
            如果你想協助翻譯或撰寫摘要，請參考
            <a href="/contribute">貢獻指南</a>。
          </p>
        </div>
      </section>
    ) : (
      <>
        <section class="page-toolbar" aria-label="篩選">
          <div class="page-toolbar-inner">
            <div class="filter-group">
              <p class="filter-label">主題：</p>
              <ul class="filter-tags">
                {allTopicTags.map((tag) => (
                  <li>
                    <TagPill label={tag} variant="topic" size="sm" href={`/bibliography?topic=${tag}`} />
                  </li>
                ))}
              </ul>
            </div>
            <div class="filter-group">
              <p class="filter-label">取得方式：</p>
              <ul class="filter-tags">
                {allAccessTypes.map((t) => (
                  <li>
                    <TagPill
                      label={t}
                      variant="status"
                      status={t === 'open-access' ? 'oa' : t === 'paywalled' ? 'paywalled' : 'oa'}
                      size="sm"
                      href={`/bibliography?access=${t}`}
                    />
                  </li>
                ))}
              </ul>
            </div>
            <div class="filter-group">
              <p class="filter-label">研究類型：</p>
              <ul class="filter-tags">
                {allStudyTypes.map((t) => (
                  <li>
                    <TagPill label={t} variant="reader" size="sm" href={`/bibliography?study=${t}`} />
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </section>

        <section class="entry-list-section">
          <ul class="paper-list">
            {sortedPapers.map((entry, i) => (
              <li class="paper-card">
                <a href={`/bibliography/${entry.id}`}>
                  {translatedSlugs.has(entry.id) && (
                    <span class="paper-card-translated" aria-label="含中文全文翻譯" title="含中文全文翻譯">譯</span>
                  )}
                  <span class="paper-card-no" aria-hidden="true">№{(i + 1).toString().padStart(3, '0')}</span>
                  <header class="paper-card-header">
                    <p class="paper-card-meta">
                      <span class="paper-card-year">{entry.data.year}</span>
                      <span class="paper-card-journal">{entry.data.journal}</span>
                    </p>
                    <h2 class="paper-card-title">{entry.data.title}</h2>
                    <p class="paper-card-authors">{entry.data.authors}</p>
                  </header>
                  <p
                    class="paper-card-curator"
                    set:html={renderInlineMarkdown(entry.data.curator_note)}
                  />
                  <ul class="paper-card-tags">
                    <li>
                      <TagPill
                        label={entry.data.access_type}
                        variant="status"
                        status={entry.data.access_type === 'open-access' ? 'oa' : 'paywalled'}
                        size="sm"
                      />
                    </li>
                    {entry.data.translation_status === 'full-translation' && (
                      <li>
                        <TagPill label="已翻譯" variant="status" status="translated" size="sm" />
                      </li>
                    )}
                    {entry.data.topic_tags.slice(0, 2).map((tag) => (
                      <li>
                        <TagPill label={tag} variant="topic" size="sm" />
                      </li>
                    ))}
                  </ul>
                </a>
              </li>
            ))}
          </ul>
        </section>
      </>
    )
  }
</BaseLayout>

<style>
  .page-hero {
    padding: var(--space-11) var(--space-5) var(--space-9);
    border-bottom: 1px solid var(--rule-fine);
  }

  .page-hero-inner {
    max-width: var(--content-width-index);
    margin: 0 auto;
  }

  /* Page Hero — V2 Polish */
  .page-eyebrow {
    font-family: var(--font-sans);
    font-size: var(--fs-eyebrow);
    text-transform: uppercase;
    letter-spacing: var(--ls-eyebrow);
    color: var(--accent-primary);
    margin: 0 0 var(--space-4);
    display: inline-flex;
    align-items: baseline;
    gap: 8px;
  }

  .page-eyebrow-num {
    font-family: var(--font-mono);
    font-weight: var(--fw-semibold);
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.04em;
  }

  .page-eyebrow-sep {
    color: var(--ink-disabled);
    font-weight: var(--fw-regular);
  }

  .page-eyebrow-name {
    font-weight: var(--fw-semibold);
  }

  .page-title {
    font-size: var(--fs-h1);
    font-weight: var(--fw-semibold);
    letter-spacing: var(--ls-h1);
    line-height: var(--lh-tight);
    margin: 0 0 var(--space-5);
  }

  .page-title-rule {
    width: 64px;
    height: 1px;
    background: var(--accent-primary);
    border: 0;
    margin: 0 0 var(--space-6);
  }

  /* Hero description 對齊 page-hero-inner（1024px），與 search/toolbar 視覺一致。
     65ch 紀律僅保留給詳情頁長文段落。 */
  .page-description {
    font-size: var(--fs-body);
    line-height: var(--lh-body);
    color: var(--ink-meta);
    margin: 0;
  }

  .page-description-en {
    font-family: var(--font-serif);
    font-size: var(--fs-body-sm);
    line-height: 1.7;
    color: var(--ink-disabled);
    margin: var(--space-2) 0 var(--space-7);
    letter-spacing: 0;
  }

  .page-description :global(strong) {
    color: var(--ink-heading);
    font-weight: var(--fw-semibold);
  }

  /* SearchBox 拉滿主內容區寬度，與下方卡片對齊 */
  .page-search {
    max-width: 100%;
  }

  /* Filter Toolbar — 多組篩選軸 */
  .page-toolbar {
    padding: var(--space-5);
    background: var(--bg-subtle);
    border-bottom: 1px solid var(--rule-fine);
  }

  .page-toolbar-inner {
    max-width: var(--content-width-index);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .filter-group {
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .filter-label {
    font-family: var(--font-sans);
    font-size: var(--fs-caption);
    color: var(--ink-meta);
    margin: 0;
    min-width: 6em;
  }

  .filter-tags {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .empty-state {
    padding: var(--space-12) var(--space-5);
  }

  .empty-state-inner {
    max-width: 60ch;
    margin: 0 auto;
    text-align: center;
  }

  .empty-state-eyebrow {
    font-family: var(--font-sans);
    font-size: var(--fs-eyebrow);
    text-transform: uppercase;
    letter-spacing: var(--ls-eyebrow);
    color: var(--ink-disabled);
    margin: 0 0 var(--space-4);
  }

  .empty-state h2 {
    font-size: var(--fs-h2);
    margin: 0 0 var(--space-5);
  }

  .empty-state p {
    color: var(--ink-meta);
  }

  .empty-state a {
    color: var(--accent-primary);
  }

  .entry-list-section {
    padding: var(--space-9) var(--space-5) var(--space-11);
  }

  .paper-list {
    max-width: var(--content-width-index);
    margin: 0 auto;
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  /* ──────────────────────────────────────────────────────
     Paper card — V2 Polish: D + 微 A
     ────────────────────────────────────────────────────── */
  .paper-card a {
    position: relative;
    display: block;
    padding: var(--space-6) var(--space-7);
    background: var(--bg-elevated);
    border: 1px solid var(--rule-fine);
    border-radius: var(--radius-sm);
    text-decoration: none;
    color: var(--ink-body);
    overflow: hidden;
    transition: border-color 150ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .paper-card a::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    bottom: 0;
    width: 0;
    background: var(--accent-primary);
    transition: width 200ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .paper-card a:hover {
    border-color: var(--accent-primary);
  }

  .paper-card a:hover::before {
    width: 3px;
  }

  .paper-card a:focus-visible {
    outline: 2px solid var(--accent-primary);
    outline-offset: 2px;
  }

  .paper-card-no {
    position: absolute;
    top: var(--space-4);
    right: var(--space-5);
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: var(--fw-medium);
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.06em;
    color: var(--ink-disabled);
    line-height: 1;
  }

  /* v0.8.0：左上角「譯」marker — 標示卡片有對應中文全文翻譯
     與右上 №001 paper-trail 編號 mirror 對位（呼應 glossary pin 設計） */
  .paper-card-translated {
    position: absolute;
    top: var(--space-4);
    left: var(--space-5);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    background: var(--accent-primary);
    color: var(--ink-inverse, #fff);
    font-family: var(--font-serif);
    font-size: 12px;
    font-weight: var(--fw-bold);
    border-radius: 2px;
    line-height: 1;
    z-index: 1;
  }

  .paper-card-header {
    padding-right: var(--space-8); /* 給編號讓位 */
  }

  .paper-card-meta {
    font-family: var(--font-sans);
    font-size: var(--fs-caption);
    color: var(--ink-meta);
    margin: 0 0 var(--space-2);
    display: flex;
    gap: var(--space-3);
    align-items: baseline;
  }

  .paper-card-year {
    font-variant-numeric: tabular-nums;
    font-weight: var(--fw-semibold);
    color: var(--ink-body);
    letter-spacing: 0.02em;
  }

  .paper-card-journal {
    font-style: italic;
  }

  /* Title underline grow on hover — ::after pseudo（不踩 gradient 鐵律） */
  .paper-card-title {
    position: relative;
    display: inline-block;
    font-size: var(--fs-h3);
    font-family: var(--font-serif);
    font-weight: var(--fw-semibold);
    margin: 0 0 var(--space-2);
    color: var(--ink-heading);
    letter-spacing: var(--ls-tight);
    line-height: var(--lh-heading);
    padding-bottom: 2px;
  }

  .paper-card-title::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 0;
    height: 1px;
    width: 0;
    background: var(--accent-primary);
    transition: width 200ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .paper-card a:hover .paper-card-title::after {
    width: 100%;
  }

  .paper-card-authors {
    font-family: var(--font-sans);
    font-size: var(--fs-body-sm);
    color: var(--ink-meta);
    margin: var(--space-2) 0 var(--space-4);
    font-style: italic;
  }

  .paper-card-curator {
    font-size: var(--fs-body-sm);
    line-height: var(--lh-body);
    color: var(--ink-body);
    margin: 0 0 var(--space-4);
    border-left: 3px solid var(--accent-citation);
    padding-left: var(--space-4);
  }

  .paper-card-tags {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  @media (prefers-reduced-motion: reduce) {
    .paper-card a,
    .paper-card a::before,
    .paper-card-title::after {
      transition: none;
    }
  }
</style>
