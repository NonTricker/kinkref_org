---
/**
 * Bibliography entry detail page — 論文詳情頁
 *
 * 動態路由：/bibliography/[paper-slug]
 */

import { getCollection, render } from 'astro:content';
import EntryLayout from '@layouts/EntryLayout.astro';
import TagPill from '@components/TagPill.astro';
import { renderParagraphs, renderInlineMarkdown } from '@/lib/inline-markdown';
import {
  caveatLabel,
  caveatTone,
  pickTrustSignal,
  pickWarnings,
} from '@/lib/caveat-labels';
import { bibliographyDescription } from '@/lib/meta-description';

export async function getStaticPaths() {
  const papers = await getCollection('bibliography');
  return papers.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const data = entry.data;

/** Render frontmatter 字串為含 inline markdown 的 HTML 段落陣列。 */
const paragraphsHtml = (text: string) => renderParagraphs(text);

// APA citation — v1.4 schema 中 doi 改選填，fallback 到 article_url 或省略
const apaTrail = data.doi
  ? `. ${data.doi}`
  : data.article_url
    ? `. ${data.article_url}`
    : '';
const apaCitation = `${data.authors} (${data.year}). ${data.title}. ${data.journal}${
  data.volume ? `, ${data.volume}` : ''
}${data.issue ? `(${data.issue})` : ''}${data.pages ? `, ${data.pages}` : ''}${apaTrail}`;

// JSON-LD: ScholarlyArticle（schema.org/ScholarlyArticle）
// authors 欄位拆解：「Wismeijer, A. A. J., & van Assen, M. A. L. M.」→ array
const authorList = data.authors
  .split(/[,&]\s*/)
  .map((a: string) => a.trim())
  .filter((a: string) => a.length > 0)
  .map((name: string) => ({ '@type': 'Person', name }));

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ScholarlyArticle',
  '@id': `https://kinkref.org/bibliography/${entry.id}#article`,
  headline: data.title,
  name: data.title,
  ...(data.original_abstract && { abstract: data.original_abstract }),
  description: data.curator_note,
  author: authorList,
  datePublished: String(data.year),
  inLanguage: 'en',
  url: `https://kinkref.org/bibliography/${entry.id}`,
  ...(data.doi && { sameAs: data.doi.startsWith('http') ? data.doi : `https://doi.org/${data.doi}` }),
  ...(data.doi && { identifier: { '@type': 'PropertyValue', propertyID: 'doi', value: data.doi } }),
  ...(data.article_url && !data.doi && { sameAs: data.article_url }),
  isPartOf: {
    '@type': 'Periodical',
    name: data.journal,
    ...(data.volume && { volumeNumber: data.volume }),
    ...(data.issue && { issueNumber: data.issue }),
  },
  ...(data.pages && { pagination: data.pages }),
  isAccessibleForFree: data.access_type === 'open-access',
  license: 'https://kinkref.org/about#license',
};

const accessStatus =
  data.access_type === 'open-access'
    ? 'oa'
    : data.access_type === 'paywalled'
      ? 'paywalled'
      : 'oa';

const pageTitle = data.title;
// v0.7.2 SEO（脈流師工單 #2）：collection 級 meta description 模板
const description = bibliographyDescription({
  title: data.title,
  authors: data.authors,
  year: data.year,
  studyType: data.study_type,
  abstractZh: data.abstract_zh,
});

// v0.7.1：拆分 caveats — trust signal (source-verified/limited) 抽到 meta bar，
// 學術警告 (methodology / dated / etc.) 留在「注意事項」section。
const trustSignal = pickTrustSignal(data.caveats);
const warnings = pickWarnings(data.caveats);
---

<EntryLayout
  title={pageTitle}
  description={description}
  collection="bibliography"
  eyebrow="文獻條目 · Paper Entry"
  contributor={data.contributor}
  contributorNote={data.contributor_note}
  reviewer={data.reviewed_by /* bibliography schema 沿用 reviewed_by 命名 */}
  lastReviewed={data.last_reviewed}
  citationText={apaCitation}
  jsonLd={jsonLd}
>
  <section class="paper-meta" aria-label="論文資訊">
    <dl>
      <div class="paper-meta-row"><dt>作者</dt><dd>{data.authors}</dd></div>
      <div class="paper-meta-row"><dt>年份</dt><dd>{data.year}</dd></div>
      <div class="paper-meta-row"><dt>期刊</dt><dd><em>{data.journal}</em></dd></div>
      {data.volume && <div class="paper-meta-row"><dt>卷期</dt><dd>{data.volume}{data.issue && `(${data.issue})`}{data.pages && `, ${data.pages}`}</dd></div>}
      {data.doi && (
        <div class="paper-meta-row">
          <dt>DOI</dt>
          <dd><a href={`https://doi.org/${data.doi.replace(/^https?:\/\/(dx\.)?doi\.org\//, '')}`} target="_blank" rel="noopener noreferrer">{data.doi}</a></dd>
        </div>
      )}
      {data.article_url && (
        <div class="paper-meta-row">
          <dt>原文連結</dt>
          <dd><a href={data.article_url} target="_blank" rel="noopener noreferrer">線上閱讀</a></dd>
        </div>
      )}
      <div class="paper-meta-row">
        <dt>取得方式</dt>
        <dd><TagPill label={data.access_type} variant="status" status={accessStatus} size="sm" /></dd>
      </div>
      {data.preprint_url && (
        <div class="paper-meta-row">
          <dt>Preprint</dt>
          <dd><a href={data.preprint_url} target="_blank" rel="noopener noreferrer">線上閱讀</a></dd>
        </div>
      )}
      <div class="paper-meta-row"><dt>研究類型</dt><dd>{data.study_type}</dd></div>
      {data.sample_size && <div class="paper-meta-row"><dt>樣本</dt><dd>{data.sample_size}{data.sample_population && ` · ${data.sample_population}`}</dd></div>}
      <div class="paper-meta-row"><dt>難度</dt><dd>{data.difficulty}</dd></div>
      <div class="paper-meta-row"><dt>翻譯進度</dt><dd>{data.translation_status}</dd></div>
      {trustSignal && (
        <div class={`paper-meta-row paper-meta-row--trust paper-meta-row--trust-${caveatTone(trustSignal.type) ?? 'neutral'}`}>
          <dt>策展深度</dt>
          <dd>
            <span class="trust-mark" aria-hidden="true">
              {caveatTone(trustSignal.type) === 'positive' ? '✓' : '⚠'}
            </span>
            <span class="trust-label">{caveatLabel(trustSignal.type)}</span>
            <span class="trust-note" set:html={renderInlineMarkdown(trustSignal.note)} />
          </dd>
        </div>
      )}
    </dl>
  </section>

  <section class="paper-section">
    <h2>中文摘要</h2>
    {paragraphsHtml(data.abstract_zh).map((html) => <p set:html={html} />)}
  </section>

  <section class="paper-section">
    <h2 class="curator-heading">策展人導讀</h2>
    <p class="curator-note" set:html={renderInlineMarkdown(data.curator_note)} />
  </section>

  {
    warnings.length > 0 && (
      <section class="paper-section">
        <h2>注意事項</h2>
        <ul class="caveat-list">
          {warnings.map((caveat) => (
            <li class="caveat-item">
              <span class="caveat-type">{caveatLabel(caveat.type)}</span>
              <span class="caveat-note" set:html={renderInlineMarkdown(caveat.note)} />
            </li>
          ))}
        </ul>
      </section>
    )
  }

  {
    data.original_abstract && (
      <section class="paper-section">
        <h2>原文 Abstract</h2>
        <blockquote class="original-abstract">{data.original_abstract}</blockquote>
      </section>
    )
  }

  <section class="paper-section">
    <h2>標籤</h2>
    <div class="tag-group">
      <p class="tag-group-label">主題</p>
      <ul class="tag-pills">
        {data.topic_tags.map((tag) => <li><TagPill label={tag} variant="topic" /></li>)}
      </ul>
    </div>
    <div class="tag-group">
      <p class="tag-group-label">讀者</p>
      <ul class="tag-pills">
        {data.reader_tags.map((tag) => <li><TagPill label={tag} variant="reader" /></li>)}
      </ul>
    </div>
  </section>

  <div class="paper-body">
    <Content />
  </div>
</EntryLayout>

<style>
  .paper-meta {
    background: var(--bg-subtle);
    padding: var(--space-7);
    border-radius: var(--radius-sm);
    margin-bottom: var(--space-9);
  }

  .paper-meta dl {
    margin: 0;
    display: grid;
    gap: var(--space-3);
  }

  .paper-meta-row {
    display: grid;
    grid-template-columns: 7em 1fr;
    gap: var(--space-4);
    font-family: var(--font-sans);
    font-size: var(--fs-body-sm);
  }

  .paper-meta-row dt {
    color: var(--ink-meta);
    font-weight: var(--fw-medium);
  }

  .paper-meta-row dd {
    margin: 0;
  }

  .paper-meta-row a {
    color: var(--accent-primary);
    word-break: break-all;
  }

  /* ──────────────────────────────────────────────────────
     v0.7.1：策展深度 trust signal row（從 caveats 抽出）
     視覺：跟其他 meta-row 同 grid 結構，但 dd 內帶 mark + label + note
     ────────────────────────────────────────────────────── */
  .paper-meta-row--trust dd {
    display: flex;
    align-items: baseline;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .trust-mark {
    font-family: var(--font-mono);
    font-weight: var(--fw-bold);
    line-height: 1;
  }

  .paper-meta-row--trust-positive .trust-mark {
    color: var(--status-oa, #2d7a3d); /* 全文閱讀 = 綠色 ✓ */
  }

  .paper-meta-row--trust-negative .trust-mark {
    color: var(--accent-citation); /* 公開摘要 = 青銅 ⚠（提醒但不警告） */
  }

  .trust-label {
    font-weight: var(--fw-medium);
    color: var(--ink-body);
  }

  .paper-meta-row--trust-positive .trust-label {
    color: var(--status-oa, #2d7a3d);
  }

  .paper-meta-row--trust-negative .trust-label {
    color: var(--accent-citation);
  }

  .trust-note {
    color: var(--ink-meta);
    font-size: var(--fs-caption);
    flex-basis: 100%;
    margin-top: 2px;
  }

  .paper-section {
    margin-bottom: var(--space-9);
  }

  .curator-heading {
    color: var(--accent-citation);
  }

  .curator-note {
    font-style: italic;
    border-left: 3px solid var(--accent-citation);
    padding-left: var(--space-5);
    color: var(--ink-body);
  }

  .caveat-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .caveat-item {
    padding: var(--space-4);
    background: var(--bg-subtle);
    border-radius: var(--radius-sm);
    font-size: var(--fs-body-sm);
  }

  .caveat-type {
    font-family: var(--font-sans);
    font-size: var(--fs-eyebrow);
    text-transform: uppercase;
    letter-spacing: var(--ls-eyebrow);
    color: var(--accent-primary);
    margin-right: var(--space-3);
  }

  .original-abstract {
    margin: 0;
    padding: var(--space-5);
    background: var(--bg-subtle);
    border-left: 3px solid var(--rule-fine);
    font-size: var(--fs-body-sm);
    line-height: var(--lh-body);
    color: var(--ink-meta);
  }

  .tag-group {
    margin-bottom: var(--space-5);
  }

  .tag-group-label {
    font-family: var(--font-sans);
    font-size: var(--fs-caption);
    color: var(--ink-meta);
    margin: 0 0 var(--space-3);
  }

  .tag-pills {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .paper-body:empty {
    display: none;
  }
</style>
