---
/**
 * BaseLayout — 全域骨架
 *
 * 提供：HTML 文件結構、meta、語言聲明、共用 Header/Footer。
 * 所有頁面 layout 應繼承此 layout 或在其上組合。
 *
 * Mood spec: ../../DESIGN.md（光影師）
 */

import '@styles/global.css';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  ogType?: 'website' | 'article';
  noindex?: boolean;
  canonical?: string;
}

const {
  title,
  description = '中文 BDSM 學術文獻策展與術語索引。Curating BDSM scholarship for the Traditional Chinese reading public.',
  ogType = 'website',
  noindex = false,
  canonical,
} = Astro.props;

const SITE_NAME = 'Kink Reference';
const SITE_URL = 'https://kinkref.org';
const fullTitle = title === SITE_NAME ? title : `${title} — ${SITE_NAME}`;
const canonicalURL = canonical ?? new URL(Astro.url.pathname, SITE_URL).toString();
---

<!doctype html>
<html lang="zh-Hant-TW">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    {noindex && <meta name="robots" content="noindex, nofollow" />}

    {/* Open Graph */}
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:locale" content="zh_TW" />

    {/* Twitter Card — 中性 summary，不放圖（站方無情色意象） */}
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />

    {/* Web fonts — Bunny Fonts CDN（GDPR 友善，不被 Google 追蹤）
        v0.4.2：載入站方 typography stack
        - IBM Plex Serif: 英文襯線（標題 / 學術書院氣）
        - Noto Serif TC: 中文襯線（標題 + body）
        - Noto Sans TC: 中文無襯線（UI / nav / metadata）
        - Inter: 英文無襯線（UI / 標籤）
        - JetBrains Mono: 等寬（DOI / IF / 編號）
        Per-character fallback：英字 IBM Plex / 中字 Noto Serif TC */}
    <link rel="preconnect" href="https://fonts.bunny.net" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.bunny.net/css?family=ibm-plex-serif:400,600,700&family=noto-serif-tc:400,600,700&family=noto-sans-tc:400,500,600&family=inter:400,500,600&family=jetbrains-mono:400,500&display=swap"
    />

    {/* Favicon — 由光影師提供 */}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" href="/favicon.ico" />

    {/* Sitemap */}
    <link rel="sitemap" href="/sitemap-index.xml" />

    {/* AI 友好 — llms.txt 在 public/ */}

    {/* Theme handling — 預設 dark（學術書院夜讀檯燈氣質）。
        防 FOUC：必須在 body render 前 set attribute。
        Light mode 由用戶主動切換（localStorage 存 "light"）。 */}
    <script is:inline>
      (function () {
        try {
          const stored = localStorage.getItem('kinkref-theme');
          const theme = stored === 'light' ? 'light' : 'dark';
          document.documentElement.setAttribute('data-theme', theme);
        } catch {
          document.documentElement.setAttribute('data-theme', 'dark');
        }
      })();
    </script>
  </head>

  <body>
    <a class="skip-link" href="#main">跳至主要內容</a>

    <Header />

    <main id="main" class="site-main">
      <slot />
    </main>

    <Footer />
  </body>
</html>

<style>
  .skip-link {
    position: absolute;
    top: -40px;
    left: var(--space-4);
    background: var(--ink-heading);
    color: var(--ink-inverse);
    padding: var(--space-2) var(--space-4);
    text-decoration: none;
    border-radius: var(--radius-sm);
    font-size: var(--fs-ui);
    z-index: var(--z-sticky-nav);
    transition: top var(--transition-fast);
  }

  .skip-link:focus {
    top: var(--space-4);
  }

  .site-main {
    min-height: calc(100vh - 200px);
  }
</style>
